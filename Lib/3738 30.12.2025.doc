ily:"Times New Roman"; font-variant:normal; line-height:normal;}.BY_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:0; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CHANGES_ORIGINS{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CLAUSE_AFTER_SRC{text-align:justify;text-justify:inter-word; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:boldl; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.CLAUSE_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT_FOR_WARNING{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.DEPARTMENTAL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.EXPLANATION{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:normal; color:#993366; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; line-height:normal;}.EXTRACT{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.FOOTNOTE{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#339966; font-weight:normal; font-size:10pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.GRIF_PARLAMENT{text-align: left; text-indent:0 mm; margin:0 0 3pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.INDEXES_ON_REF{text-align:left;text-indent:0cm;margin:3pt 0.9cm 3pt 0.95cm;font-style:normal;color:#008000;font-weight:normal;font-size:11pt;font-family:"Times New Roman"; font-variant:normal;line-height:1.0;}.IS_TABLE_FOR_LIST_TEMP{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.NEW_EDITION{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:lowercase; font-variant:normal; line-height:normal;}.OFFICIAL_SOUR_TEXT{text-align:right; font-size:8pt; font-family:Arial, Helvetica, sans-serif; border: 1px solid #A9DBFC; background-color: #E6EDFF;}.PUBLICATION_ORIGIN{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE_STAMPS_PLACEHOLDER{text-align:justify; text-justify:inter-word; text-indent:0; margin:4 10; vertical-align:text-top; flow:left;}.SIGNATURE_STAMP_TEXT{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; vertical-align:baseline!important;}.SIGNATURE_WITH_BOLD{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TABLE_STD{background:#ffffff;color:#000000;margin:4pt;font-size:12pt;width:100%;height:100%;overflow:visible;}.TEXT_15_LEFT{text-align: left; text-indent:30 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_30_LEFT{text-align: left; text-indent:45 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD{text-align:justify;  text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;text-indent:15mm;}.TEXT_BOLD_CENTER{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD_RIGHT{text-align:right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_CENTER{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_AFTER_SRC{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_DEFAULT{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_ITALIC{text-align:justify; text-indent:0; margin:0; font-style:italic; color:#000080; font-weight:italic; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal; text-indent:15mm}.TEXT_RIGHT{text-align: right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}DIV#theSysCssID TABLE{background-color:ivory;color:#000000;border-collapse:separate;font:x-small Tahoma;table-layout:auto;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theSysCssID TABLE TD,TH{border:1px solid #000000;cursor:auto;min-height:8pt;padding:1px 1px 1px 2px;vertical-align:top;white-space:normal;word-wrap:break-word;display:block!important;visibility:visible!important;}DIV#theNormCssID TABLE{background-color:#f5f5f5;color:red;border:1px solid red;font:small Verdana;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNormCssID TABLE TD,TH{border:1px solid red;cursor:auto;min-height:8pt;padding:2px 2px 2px 3px;vertical-align:top;white-space:normal;word-wrap:normal;display:block!important;visibility:visible!important;}DIV#theDefCssID TABLE{background-color:#ffffff;color:#000000;border:1px solid #000000;border-collapse:collapse;font:normal normal normal small/normal Times New Roman;table-layout:fixed;text-align:left;text-decoration:none;text-indent:0;text-transform:none;width:100%;word-spacing:normal;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theDefCssID TABLE TD,TH{background-color:#ffffff;color:#000000;border:1px solid #000000;cursor:auto!important;font:normal normal normal small/normal Times New Roman;min-height:8pt;padding:1px 1px 1px 2px;text-align:left;text-decoration:none;text-indent:0;text-transform:none;vertical-align:top;white-space:normal;word-wrap:break-word;word-spacing:normal;display:block!important;visibility:visible!important;}DIV#theNotCssID TABLE{position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNotCssID TABLE TD,TH,CAPTION{display:block!important;visibility:visible!important;}A#tabBoxDisable TABLE TD,TH{color:#808080;border-color:#808080;}.tabBox{display:inline-block;} .OFFICIAL_SOUR_TEXT{display:none;}</style>
</head>
<body style='tab-interval:.5in'>
<div class=Section1>
﻿<div id="divCont" style="background:#ffffff;border:none;margin:auto;"><div class="ACCEPTING_BODY"><a id="7972780">Ўзбекистон Республикаси Соғлиқни сақлаш вазирининг</a></div><div class="ACT_FORM"><a id="7972781">буйруғи</a></div><div class="ACT_TITLE"><a id="7972783">Умумий фармакопея мақолаларини, фармакопея мақолаларини ишлаб чиқиш ва уларни Давлат фармакопеясига киритиш тартиби тўғрисидаги низомни тасдиқлаш ҳақида</a></div><div class="DEPARTMENTAL"><a id="7972789">[Ўзбекистон Республикаси Адлия вазирлиги томонидан 2025 йил 30 декабрда рўйхатдан ўтказилди, рўйхат рақами 3738]</a></div><div class="BY_DEFAULT"><a id="7972792"></a></div><div class="ACT_TEXT"><a id="7972793">Ўзбекистон Республикасининг «Дори воситалари ва фармацевтика фаолияти тўғрисида»ги <a href="http://lex.uz/ru/docs/2856464">Қонуни</a> ва Ўзбекистон Республикаси Президентининг 2025 йил 8 сентябрдаги ПФ-161-сон «Ислоҳотларни ҳуқуқий жиҳатдан таъминлаш самарадорлигини ошириш ҳамда ижтимоий муносабатларни тартибга солишда вазирлик ва идораларнинг масъулияти ва ташаббускорлигини кучайтириш чора-тадбирлари тўғрисида»ги <a href="http://lex.uz/ru/docs/7719729">Фармонига</a> мувофиқ буюраман:</a></div><div class="ACT_TEXT"><a id="7972794">1. Умумий фармакопея мақолаларини, фармакопея мақолаларини ишлаб чиқиш ва уларни Давлат фармакопеясига киритиш тартиби тўғрисидаги низом <a href="javascript:scrollText(7972830)">иловага</a> мувофиқ тасдиқлансин.</a></div><div class="ACT_TEXT"><a id="7972796">2. Мазкур буйруқ Ўзбекистон Республикаси Президенти ҳузуридаги Тадбиркорлик субъектларининг ҳуқуқлари ва қонуний манфаатларини ҳимоя қилиш бўйича вакил, Вазирлар Маҳкамаси ҳузуридаги Ўзбекистон техник жиҳатдан тартибга солиш агентлиги ҳамда Ўзбекистон Республикаси Савдо-саноат палатаси билан келишилган.</a></div><div class="ACT_TEXT"><a id="7972798">3. Ушбу буйруқ расмий эълон қилинган кундан эътиборан кучга киради.</a></div><div class="SIGNATURE"><a id="7972800">Вазир А. ХУДАЯРОВ</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972801">Тошкент ш.,</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972802">2025 йил 12 декабрь,</a></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><a id="7972803">14-сон</a></div><div class="TEXT_CENTER"><a id="7972804">Келишилди:</a></div><div class="SIGNATURE"><a id="7972807">Тадбиркорлик субъектларининг ҳуқуқлари ва қонуний манфаатларини ҳимоя қилиш бўйича вакил ўринбосари Ж. УРУНОВ</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972808"></a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972809">2025 йил 25 ноябрь</a></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><a id="7972810"></a></div><div class="SIGNATURE"><a id="7972819">Ўзбекистон техник жиҳатдан тартибга солиш агентлиги директори А. ЖУМАНАЗАРОВ</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972820"></a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972822">2025 йил 13 ноябрь</a></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><a id="7972823"></a></div><div class="SIGNATURE"><a id="7972825">Савдо-саноат палатаси раиси Д. ВАХАБОВ</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972826"></a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7972827">2025 йил 13 ноябрь</a></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><a id="7972828"></a></div><div class="BY_DEFAULT"><a id="7972829"></a></div><div class="APPL_BANNER_LANDSCAPE_TITLE"><a id="7972830">Ўзбекистон Республикаси соғлиқни сақлаш вазирининг 2025 йил 12 декабрдаги 14-сон <a href="javascript:scrollText()">буйруғига</a><br />ИЛОВА</a></div><div class="ACT_TITLE_APPL"><a id="7972832">Умумий фармакопея мақолаларини, фармакопея мақолаларини ишлаб чиқиш ва уларни Давлат фармакопеясига киритиш тартиби тўғрисида</a></div><div class="ACT_FORM"><a id="7972833">НИЗОМ</a></div><div class="BY_DEFAULT"><a id="7972834"></a></div><div class="ACT_TEXT"><a id="7972835">Мазкур Низом умумий фармакопея мақолаларини, фармакопея мақолаларини ишлаб чиқиш ва уларни Давлат фармакопеясига киритиш тартибини белгилайди.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7972836">1-боб. Умумий қоидалар</a></div><div class="ACT_TEXT"><a id="7972837">1. Ушбу Низомда қуйидаги тушунчалар қўлланилади:</a></div><div class="ACT_TEXT"><a id="7972838"><strong>Давлат фармакопеяси</strong> — дори воситаларига ва тиббий жиҳозларга доир талабларни, умумий фармакопея мақолаларини, фармакопея мақолаларини, дори воситаларининг ва тиббий буюмларнинг сифатини назорат қилиш усулларини ўз ичига олган ҳужжатлар тўплами бўлган расмий нашр;</a></div><div class="ACT_TEXT"><a id="7972839"><strong>умумий фармакопея мақолалари</strong> — дори воситаларининг, тиббий жиҳозларнинг сифатига, доривор ўсимлик хом ашёсига, уларнинг сифатини назорат қилиш усулларига, дори воситаларининг сифатини назорат қилишда фойдаланиладиган стандарт намуналарга, реактивларга, дори воситаларини ишлаб чиқаришда фойдаланиладиган жойлаш-ўраш материалларига қўйиладиган умумий талабларни белгилайдиган ҳужжатлар;</a></div><div class="ACT_TEXT"><a id="7972840"><strong>фармакопея мақолалари</strong> — муайян дори воситасининг, тиббий жиҳознинг, доривор ўсимлик хом ашёсининг, ёрдамчи модданинг сифатига доир талабларни белгилайдиган ҳужжатлар;</a></div><div class="ACT_TEXT"><a id="7972841"><strong>дунёнинг етакчи фармакопеялари</strong> — Жаҳон соғлиқни сақлаш ташкилоти Халқаро фармакопеяси, шунингдек, Фармакопея дискуссион гуруҳи (PDG) — халқаро ташкилотига аъзо давлатлар фармакопеялари;</a></div><div class="ACT_TEXT"><a id="7972842"><strong>дори воситалари</strong> — касалликлар профилактикаси, уларга ташхис қўйиш ва уларни даволаш, шунингдек одам организмининг ҳолати ва функцияларини ўзгартириш учун тиббиёт амалиётида қўлланилишига рухсат этилган дори моддалари (субстанциялар) ва ёрдамчи моддалар асосида олинган воситалар, дори моддалари (субстанциялар), дори препаратлари;</a></div><div class="ACT_TEXT"><a id="7972843"><strong>тиббий жиҳозлар</strong> — касалликлар профилактикаси, ташхис қўйиш, даволаш, беморларни реабилитация қилиш ва (ёки) санаб ўтилган жараёнларни таъминлаш учун, шунингдек одам организмининг ҳолати ва функцияларини аниқлаш, тиклаш, алмаштириш ҳамда ўзгартириш, мониторинг қилиш, ҳомиладорликнинг олдини олиш учун тиббиёт амалиётида қўлланилишига рухсат этилган, қўлланилиши натижасида одам организмига фармакологик, иммунологик ёки метаболик таъсир кўрсатмайдиган, айрим ҳолда, мажмуа ёки тизимлар сифатида қўлланиладиган жиҳозлар, аппаратлар, ускуналар, приборлар, асбоблар, қурилмалар, мажмуалар ва дастурий таъминотлар;</a></div><div class="ACT_TEXT"><a id="7972845"><strong>ариза берувчи</strong> — корхона фармакопея мақоласида назарда тутилган талабларни Давлат фармакопеясига киритиш учун таклифлар бериш мақсадида Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги ҳузуридаги «Фармацевтика маҳсулотлари хавфсизлиги маркази» давлат муассасасига (бундан буён матнда Марказ деб юритилади) мурожаат қилувчи дори воситалари ёки тиббий жиҳозларни рўйхатдан ўтказилганлик гувоҳномаси эгаси;</a></div><div class="ACT_TEXT"><a id="7972846"><strong>манфаатдор шахслар</strong> — Давлат фармакопеясига дори воситалари ва тиббий жиҳозларнинг сифатига ва уларни назорат қилиш усулларига оид янги талабларни киритиш учун таклифлар бериш мақсадида Марказга мурожаат қилувчи, фармацевтика фаолияти билан шуғулланувчи ташкилотлар, олий таълим муассасалари ва илмий ташкилотлар.</a></div><div class="ACT_TEXT"><a id="7972848">2. Умумий фармакопея мақолалари, фармакопея мақолалари қуйидагиларга нисбатан татбиқ этилмайди:</a></div><div class="ACT_TEXT"><a id="7972849">трансфузиологияда ишлатиладиган қон ва унинг таркибий қисмларига;</a></div><div class="ACT_TEXT"><a id="7972850">дори воситаларини тайёрлаш учун кейинчалик саноат йўли билан қайта ишланиши талаб этиладиган келиб чиқиши ҳайвонотга мансуб хомашёларга;</a></div><div class="ACT_TEXT"><a id="7972851">дорихоналарда тайёрланадиган дори воситаларига;</a></div><div class="ACT_TEXT"><a id="7975220">ветеринарияда қўлланиладиган дори воситалари ва жиҳозларга.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7972852">2-боб. Умумий фармакопея мақолаларининг, фармакопея мақолаларининг тузилиши ва уларга қўйиладиган талаблар</a></div><div class="ACT_TEXT"><a id="7972853">3. Умумий фармакопея мақолалари, фармакопея мақолалари уларнинг мазмунига мувофиқ бўлган аниқ ва равон қисқа номга эга бўлиши керак.</a></div><div class="ACT_TEXT"><a id="7972855">4. Умумий фармакопея мақолалари, фармакопея мақолаларининг матни лўнда, оддий ва равон тилда баён этилиши керак. Бунда умумий фармакопея мақолалари, фармакопея мақолаларининг ҳар бир банди тўлиқ ва тугалланган маъно ҳамда мазмунга эга бўлиши лозим.</a></div><div class="ACT_TEXT"><a id="7972856">5. Умумий фармакопея мақолалари, фармакопея мақолаларида қуйидагиларнинг қўлланилишига йўл қўйилмайди:</a></div><div class="ACT_TEXT"><a id="7972857">оғзаки нутқ шакллари;</a></div><div class="ACT_TEXT"><a id="7972858">давлат тилида тенг маъноли сўзлар ва тушунчалар бўлган тақдирда, хорижий тилларнинг атамалари;</a></div><div class="ACT_TEXT"><a id="7972859">эскирган ҳамда кўп маънони англатадиган сўзлар ва иборалар, мажозий таққослашлар, сифатлашлар, киноялар.</a></div><div class="ACT_TEXT"><a id="7972860">6. Умумий фармакопея мақолалари, фармакопея мақолаларининг матни умумеътироф этилган грамматик, орфографик ва пунктуация қоидалари асосида тузилади.</a></div><div class="ACT_TEXT"><a id="7972861">7. Умумий фармакопея мақолалари, фармакопея мақолаларида қўлланиладиган атамаларнинг таърифлари ушбу умумий фармакопея мақолалари, фармакопея мақолаларида келтирилади.</a></div><div class="ACT_TEXT"><a id="7972862">8. Умумий фармакопея мақолалари, фармакопея мақолаларида умумий қабул қилинган қисқартмалар қўлланилиши ва бошқа қисқартмаларга тушунчалар берилиши мумкин.</a></div><div class="ACT_TEXT"><a id="7972863">9. Умумий фармакопея мақолалари, фармакопея мақолаларининг матни қуйидаги тузилиш элементларига бўлиниши мумкин: бўлимлар, кичик бўлимлар, боблар, бандлар, кичик бандлар. Бўлимлар бандларга ёки тегишли бандлар билан кичик бўлимларга бўлиниши мумкин. Бандлар кичик бандларга бўлиниши мумкин.</a></div><div class="ACT_TEXT"><a id="7972864">Ҳар битта банд ёки кичик банд умумий фармакопея мақолалари, фармакопея мақолаларининг алоҳида қоидаларини ўз ичига олиши ҳамда тўлиқ ва тугалланган матнга эга бўлиши керак.</a></div><div class="ACT_TEXT"><a id="7972866">10. Умумий фармакопея мақолалари, фармакопея мақолаларининг бўлимлари ва кичик бўлимлари сарлавҳаларга эга бўлиши лозим. Сарлавҳаларда тегишли бўлимлар, кичик бўлимлар, бандларнинг мазмуни аниқ ва қисқа акс эттириши керак.</a></div><div class="ACT_TEXT"><a id="7972867">11. Умумий фармакопея мақолалари, фармакопея мақолалари саҳифаларининг тартиб рақами саҳифанинг пастки марказида жойлаштирилиши керак ҳамда 1 рақамидан бошлаб рақамланади.</a></div><div class="ACT_TEXT"><a id="7972869">Умумий фармакопея мақолалари, фармакопея мақолалари, қоида тариқасида, Misrosoft Word редакторидан ва қуйидаги параметрлардан фойдаланган ҳолда тайёрланади:</a></div><div class="ACT_TEXT"><a id="7972870">«Times New Roman» 8 — 12 ўлчамли шрифт;</a></div><div class="ACT_TEXT"><a id="7972872">саҳифанинг чап ҳошияси 3 см, ўнг ҳошияси 1,5 см, паст ва юқори ҳошиялари 2 см;</a></div><div class="ACT_TEXT"><a id="7972874">биринчи қаторнинг сатр бошиси 0,5 см бўлиши лозим.</a></div><div class="ACT_TEXT"><a id="7972876">12. Умумий фармакопея мақолалари, фармакопея мақолалари матнини тайёрлашда грек ёки бошқа алифболарнинг ҳарфлари, формулалар, алоҳида шартли белгилар Microsoft Word редакторидан фойдаланган ҳолда белгиланиши керак. Бунда ёзилган матннинг зичлиги, қолган матн зичлигига яқинлаштирилган бўлиши керак.</a></div><div class="ACT_TEXT"><a id="7972878">13. Умумий фармакопея мақолалари, фармакопея мақолалари давлат тилида ишлаб чиқилади ва бошқа тилларга таржима қилиниши мумкин.</a></div><div class="ACT_TEXT"><a id="7972879">14. Умумий фармакопея мақолалари, фармакопея мақолаларига ҳуқуқий нормалар киритилиши тақиқланади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7972881">3-боб. Умумий фармакопея мақолалари, фармакопея мақолаларини ишлаб чиқиш</a></div><div class="ACT_TEXT"><a id="7972882">15. Умумий фармакопея мақолалари, фармакопея мақолаларини ишлаб чиқиш Марказ ходимларидан иборат таркибда Ўзбекистон Республикаси соғлиқни сақлаш вазирининг буйруғи билан ташкил этиладиган котибият, ишчи гуруҳ, ихтисослаштирилган эксперт комиссияси, таҳририят кенгаши ва таҳририят ҳайъати томонидан амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7972883">Бунда ишчи гуруҳ, ихтисослаштирилган эксперт комиссияси, таҳририят кенгаши ва таҳририят ҳайъати таркибига бошқа давлат органлари ва ташкилотларидан ҳам мутахассислар жалб этилиши мумкин.</a></div><div class="ACT_TEXT"><a id="7972884">16. Умумий фармакопея мақолалари, фармакопея мақолалари ариза берувчи ва манфаатдор шахсларнинг таклифлари ҳамда илм-фан ва технологияларнинг ривожланишини инобатга олган ҳолда Марказ раҳбари томонидан тасдиқланган йиллик режа асосида ишлаб чиқилади.</a></div><div class="ACT_TEXT"><a id="7972888">17. Умумий фармакопея мақолалари, фармакопея мақолалари қуйидагилар инобатга олинган ҳолда ишлаб чиқилади:</a></div><div class="ACT_TEXT"><a id="7972889">илмий тадқиқотларнинг (синашнинг) ва ўлчашнинг натижалари;</a></div><div class="ACT_TEXT"><a id="7972890">тиббиёт, фармацевтика ҳамда бошқа илм-фан ва техниканинг замонавий ютуқлари;</a></div><div class="ACT_TEXT"><a id="7972892">дори воситалари ва тиббий жиҳозларнинг янги турларининг сифати ҳамда уларнинг сифатини назорат қилиш усулларини қўллаш орқали орттирилган амалий тажрибалар;</a></div><div class="ACT_TEXT"><a id="7972894">дунёнинг етакчи фармакопеялари, халқаро (минтақавий) стандартлар ва хорижий мамлакатларнинг стандартлари, дори воситалари ва тиббий жиҳозларнинг сифатини назорат қилиш соҳасидаги халқаро ташкилотларнинг тавсиялари ҳамда дори воситалари ва тиббий жиҳозларга доир талабларни белгилайдиган бошқа ҳужжатлар.</a></div><div class="ACT_TEXT"><a id="7972895">18. Умумий фармакопея мақолалари, фармакопея мақолаларини ишлаб чиқиш қуйидаги босқичлардан иборат:</a></div><div class="ACT_TEXT"><a id="7972896">котибият умумий фармакопея мақолалари, фармакопея мақолаларини ишлаб чиқиш бўйича йиллик иш режани тайёрлайди ва тасдиқлаш учун Марказ раҳбарига тақдим этади ҳамда ариза берувчи ва манфаатдор шахсларнинг таклифларини умумлаштириб ишчи гуруҳга киритади;</a></div><div class="ACT_TEXT"><a id="7972898">ишчи гуруҳ умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини мазкур Низомнинг <a href="javascript:scrollText(7972888)">17-бандида</a> келтирилган талаблардан келиб чиқиб тайёрлайди ва уларни кўриб чиқиш учун ихтисослаштирилган эксперт комиссиясига тақдим этади;</a></div><div class="ACT_TEXT"><a id="7972899">ихтисослаштирилган эксперт комиссияси ишчи гуруҳ томонидан киритилган умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини ўрганиб чиқиб, уларни илмий таҳрирлайди;</a></div><div class="ACT_TEXT"><a id="7972901">таҳририят кенгаши ихтисослаштирилган эксперт комиссияси томонидан илмий таҳрирланган фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини мазкур Низомнинг <a href="javascript:scrollText(7972904)">19-бандига</a> асосан баҳолайди ва баҳолаш натижаларини ҳамда фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини таҳририят ҳайъатига тақдим этади;</a></div><div class="ACT_TEXT"><a id="7975320">таҳририят ҳайъати фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини ва таҳририят кенгаши томонидан тақдим этилган баҳолаш натижаларини кўриб чиқиб, яхши баҳоланган умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини тасдиқлашни тавсия этиш учун Ўзбекистон Республикаси Соғлиқни сақлаш вазирлигига (бундан буён матнда Вазирлик деб юритилади) киритади ёки умумий фармакопея мақолалари, фармакопея мақолалари қониқарли ва қониқарсиз баҳоланган ҳолатларда уларни қайта ишлаш учун ишчи гуруҳга қайтаради.</a></div><div class="ACT_TEXT"><a id="7972904">19. Таҳририят кенгашининг ҳар бир аъзоси томонидан бошқа аъзоларидан мустақил ҳолда умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини баҳолаш 100 баллик тизимда амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7972906">Бунда, таҳририят кенгашининг ҳар бир аъзоси умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини қуйидаги мезонларга асосан баҳолайди:</a></div><div class="ACT_TEXT"><a id="7972908">илмий асосланганлиги, дунёнинг етакчи фармакопеялари, халқаро (минтақавий) стандартлар билан уйғунлашганлиги ҳамда мазкур Низомнинг <a href="javascript:scrollText(7972852)">2-бобида</a> белгиланган талаблар асосида ишлаб чиқилганлиги учун — 80 — 100 балл (яхши);</a></div><div class="ACT_TEXT"><a id="7972909">илмий асосланмаганлиги, дунёнинг етакчи фармакопеялари, халқаро (минтақавий) стандартлар билан қисман уйғунлашганлиги ҳамда мазкур Низомнинг <a href="javascript:scrollText(7972852)">2-бобида</a> белгиланган талаблар асосида ишлаб чиқилганлиги учун — 55 — 79 балл (қониқарли);</a></div><div class="ACT_TEXT"><a id="7972910">илмий асосланмаганлиги, дунёнинг етакчи фармакопеялари, халқаро (минтақавий) стандартлар уйғунлашмаганлиги ҳамда мазкур Низомнинг <a href="javascript:scrollText(7972852)">2-бобида</a> белгиланган талаблар асосида ишлаб чиқилмаганлиги учун — 0 — 54 балл (қониқарсиз).</a></div><div class="ACT_TEXT"><a id="7972912">20. Умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳалари ишлаб чиқишнинг бошланиши ва якунланиши тўғрисидаги ахборот Марказнинг расмий веб-сайтида жойлаштирилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7972913">4-боб. Умумий фармакопея мақолаларини, фармакопея мақолаларини Давлат фармакопеясига киритиш</a></div><div class="ACT_TEXT"><a id="7972914">21. Вазирлик таҳририят ҳайъати томонидан тасдиқлашни тавсия этиш учун киритилган умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини улар киритилган кундан бошлаб ўн беш иш кунида кўриб чиқади ва қуйидаги қарорлардан бирини қабул қилади:</a></div><div class="ACT_TEXT"><a id="7972916">Умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини тасдиқлаш ва Давлат фармакопеясига киритиш;</a></div><div class="ACT_TEXT"><a id="7972918">умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини тасдиқлашни рад этиш.</a></div><div class="ACT_TEXT"><a id="7972919">22. Умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини қуйидаги ҳолларда тасдиқлаш ва Давлат фармакопеясига киритиш рад этилиши мумкин, агар:</a></div><div class="ACT_TEXT"><a id="7972921">1) қонунчилик ҳужжатларига зид бўлса;</a></div><div class="ACT_TEXT"><a id="7972922">2) илмий асосланмаган, дунёнинг етакчи фармакопеялари, халқаро (минтақавий) стандартлар уйғунлашмаган бўлса;</a></div><div class="ACT_TEXT"><a id="7972924">3) мазкур Низомнинг <a href="javascript:scrollText(7972852)">2-бобида</a> белгиланган талаблар асосида ишлаб чиқилмаган бўлса.</a></div><div class="ACT_TEXT"><a id="7972925">23. Вазирлик томонидан умумий фармакопея мақолалари, фармакопея мақолаларининг лойиҳаларини тасдиқлаш ва Давлат фармакопеясига киритиш тўғрисидаги қарор қабул қилинганидан сўнг, улар Давлат фармакопеясига киритилади.</a></div><div class="ACT_TEXT"><a id="7972931">24. Умумий фармакопея мақолалари, фармакопея мақолалари Давлат фармакопеясига киритилганидан кейин уларни амалиётга жорий этиш муддати Вазирлик томонидан белгиланмаган бўлса, камида олти ойдан кейин кучга киради.</a></div><div class="ACT_TEXT"><a id="7972932">25. Давлат фармакопеяси Вазирлик томонидан беш йилда камида бир марта чоп этилади. Давлат фармакопеясининг қайта нашрлари оралиғидаги даврда Давлат фармакопеясига киритилган умумий фармакопея мақолалари, фармакопея мақолалари иловалар тарзида чоп этилади.</a></div><div class="ACT_TEXT"><a id="7972934">26. Давлат фармакопеясига киритилган умумий фармакопея мақолалари, фармакопея мақолалари ҳақида ахборот Марказнинг расмий веб-сайтига жойлаштирилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7972935">5-боб. Давлат фармакопеясига киритилган умумий фармакопея мақолаларига, фармакопея мақолаларига ўзгартириш ва қўшимчалар киритиш ёки уларни Давлат фармакопеясидан чиқариш</a></div><div class="ACT_TEXT"><a id="7972938">27. Давлат фармакопеясига киритилган умумий фармакопея мақолаларига, фармакопея мақолаларига ўзгартириш ва қўшимчалар киритиш ушбу Низомнинг <a href="javascript:scrollText(7972888)">17-бандида</a> келтирилган талаблардаги ўзгаришлар муносабати билан, тиббиёт, фармацевтика ҳамда фан ва технологиялар инновацион ютуқлари такомиллаштириш талаб этилган тақдирда, шу жумладан, Вазирлик томонидан янги умумий фармакопея мақолалари, фармакопея мақолалари тасдиқланиши муносабати билан, шунингдек ариза берувчи ва манфаатдор шахслар ташаббуси бўйича амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7972939">28. Давлат фармакопеясига киритилган умумий фармакопея мақолаларига, фармакопея мақолаларига ўзгартириш ва қўшимчалар киритиш лойиҳаси ушбу Низомнинг <a href="javascript:scrollText(7972852)">2</a> ва <a href="javascript:scrollText(7972881)">3-бобларида</a> назарда тутилган тартибларда ишлаб чиқилиб, Вазирликка киритилади.</a></div><div class="ACT_TEXT"><a id="7972983">29. Давлат фармакопеясига киритилган умумий фармакопея мақолаларига, фармакопея мақолаларига ўзгартириш ва қўшимчалар киритишда уларнинг бўлимлар, кичик бўлимлар, боблар, бандлар, кичик бандларининг (агар мавжуд бўлса) рақамланиши ўзгармайди.</a></div><div class="ACT_TEXT"><a id="7972994">30. Давлат фармакопеясига киритилган умумий фармакопея мақолаларини, фармакопея мақолаларини Давлат фармакопеясидан чиқариш учун қуйидагилар асос бўлади:</a></div><div class="ACT_TEXT"><a id="7972997">умумий фармакопея мақолалари, фармакопея мақолалари қонунчилик ҳужжатларида белгиланган талабларига зид бўлиши;</a></div><div class="ACT_TEXT"><a id="7972998">умумий фармакопея мақолалари, фармакопея мақолаларининг ўрнига янги умумий фармакопея мақолалари, фармакопея мақолалари амалга киритилганлиги;</a></div><div class="ACT_TEXT"><a id="7973001">янги илмий тадқиқотларнинг (синашнинг) ва замонавий технологиялар амалиётга жорий этилганлиги;</a></div><div class="ACT_TEXT"><a id="7973002">умумий фармакопея мақолалари, фармакопея мақолаларининг қўллашнинг долзарблиги йўқолганлиги;</a></div><div class="ACT_TEXT"><a id="7973003">ариза берувчи ва манфаатдор шахсларнинг таклифлари асосида (бунда таклифлар асослантирилган бўлиши лозим).</a></div><div class="ACT_TEXT"><a id="7973005">31. Давлат фармакопеясига киритилган умумий фармакопея мақолалари, фармакопея мақолаларини Давлат фармакопеясидан чиқариш масалалари таҳририят кенгаши томонидан кўриб чиқилиб, мазкур Низомнинг <a href="javascript:scrollText(7972994)">30-бандида</a> келтирилган ҳолатлар асосида таҳлил қилинади ва унинг натижалари таҳририят ҳайъатига тақдим этилади.</a></div><div class="ACT_TEXT"><a id="7973006">Таҳририят ҳайъати томонидан таҳририят кенгашининг таҳлил натижалари ўрганиб чиқилиб, Давлат фармакопеясига киритилган умумий фармакопея мақолалари, фармакопея мақолаларини Давлат фармакопеясидан чиқариш бўйича тавсиялар Вазирликка киритилади.</a></div><div class="ACT_TEXT"><a id="7973008">32. Вазирлик таҳририят ҳайъат тавсиясига асосан Давлат фармакопеясига киритилган умумий фармакопея мақолаларини, фармакопея мақолаларини Давлат фармакопеясидан чиқариш ёки чиқаришни рад этиш ҳақида тавсия киритилган кундан бошлаб етти иш куни ичида қарор қабул қилади.</a></div><div class="ACT_TEXT"><a id="7973010">33. Давлат фармакопеясига киритилган умумий фармакопея мақолаларига, фармакопея мақолаларига киритилган ўзгартириш ва қўшимчалар ёки уларни Давлат фармакопеясидан чиқариш ҳақидаги ахборот Марказнинг расмий веб-сайтига жойлаштирилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7973013">6-боб. Якуний қоида</a></div><div class="ACT_TEXT"><a id="7973014">34. Мазкур Низом талаблари бузилишида айбдор бўлган шахслар қонунчилик ҳужжатларига мувофиқ жавобгар бўладилар.</a></div><br /><div class="PUBLICATION_ORIGIN"><label id="s1089"></label><a id="7972790">(Қонунчилик маълумотлари миллий базаси, 06.01.2026 й., 10/26/3738/0013-сон)</a></div></div>
</div>
</body>
</html>