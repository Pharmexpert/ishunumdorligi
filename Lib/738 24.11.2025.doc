ew Roman&quot;,serif">2.8.</span></span></span></p></td><td style="border-bottom:1px solid black; width:21%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none" valign="top"><p class="CxSpMiddle" style="text-align:justify"><span style="background:white"><span style="line-height:normal"><span style="tab-stops:9.0cm"><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Стерилизация жараёни тўғрисида маълумотлар, шу жумладан жараён валидацияси, микроорганизмларга текшириш натижалари (биологик юклама даражаси), бактериал эндотоксинлар, стерилликни (зарур ҳолларда) аниқлаш синов усуллари кўрсатилган ҳолда ва қадоқлаш валидацияси тўғрисидаги маълумотлари. </span></span><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">(*) (**)</span></span></span></span></span></p></td><td style="border-bottom:1px solid black; width:15%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none" valign="top"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">+</span></span></span></p></td><td style="border-bottom:1px solid black; width:14%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none" valign="top"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">+</span></span></span></p></td><td style="border-bottom:1px solid black; width:14%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none" valign="top"><p align="center" class="CxSpMiddle" style="text-alig