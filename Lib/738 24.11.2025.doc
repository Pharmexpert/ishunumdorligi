<style type="text/css">BODY{scrollbar-base-color:scrollbar;scrollbar-highlight-color:white;scrollbar-darkshadow-color:scrollbar;scrollbar-shadow-color:white;}#divCont DIV{border:none;white-space:normal;}#divCont IMG{float:none;vertical-align:middle;}#divCont A{text-decoration:none;}#divCont A:link{color:#008080;}#divCont A:visited{color:#008080;}#divCont A:hover{color:#ff0000;}#divCont P{margin:0px;padding:0px;line-height:1.0;}#divCont LABEL{display:none;}.aExp{text-align:left;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:normal;color:red;font-weight:600;font-size:12pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.aOAD{width:100%;text-align:right;text-indent:0px;margin:0pt 0pt 12pt 0pt;font-style:italic;color:#808080;font-weight:400;font-size:10pt;font-family:"Times New Roman";font-variant:normal;line-height:1.0;}.signCont{text-align:center;margin:0pt 0pt 12pt 0px;text-indent:0pt;}.mrkup{background-color:#00008B!important;color:#FFFFFF!important;}.mrkupNav{color:#00008B!important;}.mrkupNav SPAN{font:12px Webdings!important;padding:0px 2px!important;}.iorRN{font-weight:600;}.iorVal{text-indent:0px;margin-left:1px;}.clausePrfx{display:inline;float:left;}.clauseSuff{display:block;width:100%;text-indent:0px;}@media print{.clausePrfx{float:none;}.clauseSuff{display:inline;width:auto;}}.ACCEPTING_BODY{text-align:center; text-indent:0; margin:0 0 0 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman";font-variant:normal; line-height:normal;text-transform:uppercase;}.ACT_ESSENTIAL_ELEMENTS{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.ACT_ESSENTIAL_ELEMENTS_NUM{text-align:center; text-indent:0; margin:0 70% 0 0; font-style:normal; color:#000000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;padding-bottom: 20px;}.ACT_FORM{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_FORM_LAW{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TEXT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.ACT_TITLE{text-align:center; text-indent:0; margin:12pt 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; text-transform:uppercase; font-variant:normal; line-height:normal;}.ACT_TITLE_APPL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 10pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_LANDSCAPE_TITLE{text-align:center; text-indent:0pt; margin:10pt 0pt 12pt 66%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TEXT{text-align:center; text-indent:0pt; margin:0pt 0pt 0pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.APPL_BANNER_PORTRAIT_TITLE{text-align:center; text-indent:0pt; margin:0pt 0pt 12pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.BY_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:0; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CHANGES_ORIGINS{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.CLAUSE_AFTER_SRC{text-align:justify;text-justify:inter-word; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:boldl; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.CLAUSE_DEFAULT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.COMMENT_FOR_WARNING{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:italic; color:#800080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.DEPARTMENTAL{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.EXPLANATION{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:3pt 0 3pt 0; font-style:normal; color:#993366; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; line-height:normal;}.EXTRACT{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.FOOTNOTE{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#339966; font-weight:normal; font-size:10pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.GRIF_PARLAMENT{text-align: left; text-indent:0 mm; margin:0 0 3pt 50%; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.INDEXES_ON_REF{text-align:left;text-indent:0cm;margin:3pt 0.9cm 3pt 0.95cm;font-style:normal;color:#008000;font-weight:normal;font-size:11pt;font-family:"Times New Roman"; font-variant:normal;line-height:1.0;}.IS_TABLE_FOR_LIST_TEMP{text-align:justify;text-justify:inter-word; text-indent:15mm; margin:0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:1.3;}.NEW_EDITION{text-align:center; text-indent:0; margin:0 0 6pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; text-transform:lowercase; font-variant:normal; line-height:normal;}.OFFICIAL_SOUR_TEXT{text-align:right; font-size:8pt; font-family:Arial, Helvetica, sans-serif; border: 1px solid #A9DBFC; background-color: #E6EDFF;}.PUBLICATION_ORIGIN{text-align:center; text-indent:0; margin:0 0 12pt 0; font-style:italic; color:#800000; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.SIGNATURE_STAMPS_PLACEHOLDER{text-align:justify; text-justify:inter-word; text-indent:0; margin:4 10; vertical-align:text-top; flow:left;}.SIGNATURE_STAMP_TEXT{text-align:center; text-indent:0; margin:0; font-style:normal; color:#000080; font-weight:normal; font-size:11pt; font-family:"Times New Roman"; font-variant:normal; vertical-align:baseline!important;}.SIGNATURE_WITH_BOLD{text-align:right; text-indent:0; margin:6pt 0 6pt 0; font-style:normal; color:#000000; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TABLE_STD{background:#ffffff;color:#000000;margin:4pt;font-size:12pt;width:100%;height:100%;overflow:visible;}.TEXT_15_LEFT{text-align: left; text-indent:30 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_30_LEFT{text-align: left; text-indent:45 mm; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD{text-align:justify;  text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;text-indent:15mm;}.TEXT_BOLD_CENTER{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_BOLD_RIGHT{text-align:right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000000; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_CENTER{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_AFTER_SRC{text-align:center; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_HEADER_DEFAULT{text-align:center; text-indent:0; margin:6pt 0 3pt 0; font-style:normal; color:#000080; font-weight:bold; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}.TEXT_ITALIC{text-align:justify; text-indent:0; margin:0; font-style:italic; color:#000080; font-weight:italic; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal; text-indent:15mm}.TEXT_RIGHT{text-align: right; text-indent:0; margin:0 0 3pt 0; font-style:normal; color:#000080; font-weight:normal; font-size:12pt; font-family:"Times New Roman"; font-variant:normal; line-height:normal;}DIV#theSysCssID TABLE{background-color:ivory;color:#000000;border-collapse:separate;font:x-small Tahoma;table-layout:auto;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theSysCssID TABLE TD,TH{border:1px solid #000000;cursor:auto;min-height:8pt;padding:1px 1px 1px 2px;vertical-align:top;white-space:normal;word-wrap:break-word;display:block!important;visibility:visible!important;}DIV#theNormCssID TABLE{background-color:#f5f5f5;color:red;border:1px solid red;font:small Verdana;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNormCssID TABLE TD,TH{border:1px solid red;cursor:auto;min-height:8pt;padding:2px 2px 2px 3px;vertical-align:top;white-space:normal;word-wrap:normal;display:block!important;visibility:visible!important;}DIV#theDefCssID TABLE{background-color:#ffffff;color:#000000;border:1px solid #000000;border-collapse:collapse;font:normal normal normal small/normal Times New Roman;table-layout:fixed;text-align:left;text-decoration:none;text-indent:0;text-transform:none;width:100%;word-spacing:normal;position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theDefCssID TABLE TD,TH{background-color:#ffffff;color:#000000;border:1px solid #000000;cursor:auto!important;font:normal normal normal small/normal Times New Roman;min-height:8pt;padding:1px 1px 1px 2px;text-align:left;text-decoration:none;text-indent:0;text-transform:none;vertical-align:top;white-space:normal;word-wrap:break-word;word-spacing:normal;display:block!important;visibility:visible!important;}DIV#theNotCssID TABLE{position:relative;margin:0pt;top:0pt;zoom:normal;z-index:auto;}DIV#theNotCssID TABLE TD,TH,CAPTION{display:block!important;visibility:visible!important;}A#tabBoxDisable TABLE TD,TH{color:#808080;border-color:#808080;}.tabBox{display:inline-block;} .OFFICIAL_SOUR_TEXT{display:none;}</style>
</head>
<body style='tab-interval:.5in'>
<div class=Section1>
﻿<div id="divCont" style="background:#ffffff;border:none;margin:auto;"><div class="ACCEPTING_BODY"><a id="7856973">Ўзбекистон Республикаси Вазирлар Маҳкамасининг</a></div><div class="ACT_FORM"><a id="7856974">қарори</a></div><div class="ACT_TITLE"><a id="7856975">Дори воситаларини давлат рўйхатидан ўтказиш тартиби тўғрисидаги ҳамда Тиббий жиҳозларни давлат рўйхатидан ўтказиш тартиби тўғрисидаги низомларни тасдиқлаш ҳақида</a></div><div class="BY_DEFAULT"><a id="7856977"></a></div><div class="ACT_TEXT"><a id="7856978">Ўзбекистон Республикасининг «Дори воситалари ва фармацевтика фаолияти тўғрисида»ги <a href="http://lex.uz/docs/2856464">Қонунига</a> мувофиқ ҳамда Ўзбекистон Республикаси Президентининг «Дори воситалари ва тиббий жиҳозлар муомаласини тартибга солишга доир қўшимча чора-тадбирлар тўғрисида» 2025 йил 19 августдаги ПФ-137-сон <a href="http://lex.uz/docs/7697210">Фармони</a> ижросини таъминлаш мақсадида Вазирлар Маҳкамаси қарор қилади:</a></div><div class="ACT_TEXT"><a id="7856980">1. Қуйидагилар:</a></div><div class="ACT_TEXT"><a id="7856981">дори воситаларини давлат рўйхатидан ўтказишга доир талаблар ва шартлар, зарур бўлган ҳужжатлар ва намуналар ҳамда давлат рўйхатидан ўтказиш тартибини назарда тутувчи Дори воситаларини давлат рўйхатидан ўтказиш тартиби тўғрисидаги низом <a href="javascript:scrollText(7857021)">1-иловага</a> мувофиқ;</a></div><div class="ACT_TEXT"><a id="7856982">тиббий жиҳозларни давлат рўйхатидан ўтказишга доир талаблар ва шартлар, зарур бўлган ҳужжатлар ва намуналар ҳамда давлат рўйхатидан ўтказиш тартибини назарда тутувчи Тиббий жиҳозларни давлат рўйхатидан ўтказиш тартиби тўғрисидаги низом <a href="javascript:scrollText(7860248)">2-иловага</a> мувофиқ тасдиқлансин.</a></div><div class="ACT_TEXT"><a id="7856983">2. Соғлиқни сақлаш вазирлиги:</a></div><div class="ACT_TEXT"><a id="7856985">а) бир ой муддатда:</a></div><div class="ACT_TEXT"><a id="7856987">ушбу қарордан келиб чиқиб, Соғлиқни сақлаш вазирлиги ҳузуридаги «Фармацевтика маҳсулотлари хавфсизлиги маркази» давлат муассасасининг (кейинги ўринларда — Марказ) дори воситалари ва тиббий жиҳозларни давлат рўйхатидан ўтказишга доир вазифа ва функциялари бўйича ўз ички идоравий ҳужжатлари қайта кўриб чиқилишини таъминласин;</a></div><div class="ACT_TEXT"><a id="7856988">дори воситаларининг сифати, хавфсизлиги ва самарадорлигини баҳолаш жараёнида иштирок этувчи кадрлар таркибини қайта кўриб чиқиш ва Марказни малакали кадрлар билан тўлдириш, уларни даврий ротация қилиш, Марказ фаолиятига доимий асосда фаолият юритувчи тажрибали хорижий экспертларни жалб қилиш чораларини кўрсин;</a></div><div class="ACT_TEXT"><a id="7856990">оригинал дори воситаларининг клиник синовлари, женерик дори воситаларининг дори шаклидан келиб чиққан ҳолда, унинг биоэквивалентлигини ўрганиш ва баҳолаш тартибини «Инсон учун қўлланиладиган дори воситаларига қўйиладиган техник талабларни уйғунлаштириш бўйича халқаро кенгаш (ICH)» талаб ва тавсиялари асосида ишлаб чиқсин ва тасдиқласин;</a></div><div class="ACT_TEXT"><a id="7856991">б) уч ой муддатда:</a></div><div class="ACT_TEXT"><a id="7856994">Марказнинг лабораторияларини модернизация қилиш, моддий-техник базасини кенгайтириш ва қувватини ошириш, Марказ ва Соғлиқни сақлаш вазирлиги ҳузуридаги Фармацевтика тармоғини ривожлантириш агентлигининг фармацевтика фаолиятини тартибга солиш соҳасидаги вазифа ва функцияларини мувофиқлаштириш, «Зарур амалиётлар (GxP)» талабларига мувофиқлик юзасидан инспекциялар ўтказиш тартибини халқаро стандартлар асосида ташкил этиш юзасидан таклифларни белгиланган тартибда Вазирлар Маҳкамасига киритсин;</a></div><div class="ACT_TEXT"><a id="7856995">халқаро талаблар асосида дори воситалари ва тиббий жиҳозларни давлат рўйхатидан ўтказишга оид ҳужжатларига қўйиладиган талаблар бўйича йўриқномаларни ҳамда дори воситалари ва тиббий жиҳозларни давлат рўйхатидан ўтказиш учун ундириладиган йиғим миқдорларини тасдиқласин;</a></div><div class="ACT_TEXT"><a id="7856996">манфаатдор вазирлик ва идоралар билан биргаликда ўзлари қабул қилган норматив-ҳуқуқий ҳужжатларни ушбу қарорга мувофиқлаштирсин;</a></div><div class="ACT_TEXT"><a id="7856997">в) 2026 йил якунига қадар Марказ ҳузуридаги лабораторияларнинг Жаҳон соғлиқни сақлаш ташкилоти томонидан преквалификациядан ўтишини ва Жаҳон соғлиқни сақлаш ташкилотининг преквалификацияланган лабораториялари рўйхатига киритилишини таъминласин;</a></div><div class="ACT_TEXT"><a id="7856998">г) давлат рўйхатидан ўтказишда устуворлик берилган дори воситалари ва тиббий жиҳозларнинг рўйхатини доимий равишда Марказнинг расмий веб-сайтида эълон қилиб борилишини таъминласин.</a></div><div class="ACT_TEXT"><a id="7856999">3. Вазирлар Маҳкамасининг 2024 йил 4 октябрдаги 628-сон қарори билан тасдиқланган Фармацевтика маҳсулотларининг постмаркетинг назоратини амалга ошириш тартиби тўғрисидаги низомнинг <a href="http://lex.uz/docs/7131955?ONDATE=05.10.2024 00#7136075">8-банди</a> қуйидаги мазмундаги тўртинчи хатбоши билан тўлдирилсин:</a></div><div class="ACT_TEXT"><a id="7857000">«давлат рўйхатидан ўтказилганлик тўғрисидаги гувоҳноманинг амал қилиш муддати лаборатория синовларисиз узайтирилган дори воситалари».</a></div><div class="ACT_TEXT"><a id="7857001">4. Ўзбекистон Республикаси Ҳукуматининг <a href="javascript:scrollText(7861127)">3-иловага</a> мувофиқ айрим қарорлари ўз кучини йўқотган деб ҳисоблансин.</a></div><div class="ACT_TEXT"><a id="7857002">5. Ушбу қарор расмий эълон қилинган кундан эътиборан уч ой ўтгач кучга киради.</a></div><div class="ACT_TEXT"><a id="7857003">6. Мазкур қарорнинг бажарилишини назорат қилиш Ўзбекистон Республикаси соғлиқни сақлаш вазири А.А. Худаяров зиммасига юклансин.</a></div><div class="SIGNATURE"><a id="7857004">Ўзбекистон Республикасининг Бош вазири А. АРИПОВ</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7857005">Тошкент ш.,</a></div><div class="ACT_ESSENTIAL_ELEMENTS"><a id="7857006">2025 йил 24 ноябрь,</a></div><div class="ACT_ESSENTIAL_ELEMENTS_NUM"><a id="7857007">738-сон</a></div><div class="BY_DEFAULT"><a id="7857020"></a></div><div class="APPL_BANNER_LANDSCAPE_TITLE"><a id="7857021">Вазирлар Маҳкамасининг 2025 йил 24 ноябрдаги 738-сон <a href="javascript:scrollText()">қарорига</a><br />1-ИЛОВА</a></div><div class="ACT_TITLE_APPL"><a id="7857023">Дори воситаларини давлат рўйхатидан ўтказиш тартиби тўғрисида</a></div><div class="ACT_FORM"><a id="7857024">НИЗОМ</a></div><div class="BY_DEFAULT"><a id="7857025"></a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857027">1-боб. Умумий қоидалар</a></div><div class="ACT_TEXT"><a id="7857028">1. Мазкур Низом дори воситаларини давлат рўйхатидан ўтказиш (кейинги ўринларда — рўйхатдан ўтказиш) тартибини белгилайди.</a></div><div class="ACT_TEXT"><a id="7857029">Ушбу Низомнинг талаблари дори воситаларининг ишлаб чиқувчилари ва ишлаб чиқарувчиларига, дори воситаларининг рўйхатдан ўтказилганлик гувоҳномаси эгаларига, уларнинг ишончли вакилларига, дори воситаларининг муомаласи соҳасидаги ваколатли ташкилотларга, экспертлар ва эксперт ташкилотларга нисбатан татбиқ этилади.</a></div><div class="ACT_TEXT"><a id="7857030">2. Ушбу Низомда қуйидаги асосий тушунчалардан фойдаланилади:</a></div><div class="ACT_TEXT"><a id="7857311"><strong>ариза берувчи</strong> — Ўзбекистон Республикаси Соғлиқни сақлаш вазирлигининг «Фармацевтика маҳсулотлари хавфсизлиги маркази» давлат муассасасига (кейинги ўринларда — Марказ) дори воситаларини рўйхатдан ўтказиш ва гувоҳнома олиш учун мурожаат қилувчи ишлаб чиқувчи, ишлаб чиқарувчи, рўйхатдан ўтказилганлик гувоҳномасининг эгаси ёки улар номидан ишончнома асосида ҳаракат қилувчи юридик шахс;</a></div><div class="ACT_TEXT"><a id="7857313"><strong>биосимиляр дори воситаси</strong> — табиий манбалардан олинадиган, таркибида рўйхатдан ўтказилган оригинал (референс) дори воситасининг таъсир этувчисини сақловчи ҳамда сифати, биологик фаоллиги, самарадорлиги ва хавфсизлиги кўрсаткичлари бўйича оригинал (референс) дори воситасига солиштириш тадқиқотлари асосида ўхшашлиги исботланган биологик дори воситаси;</a></div><div class="ACT_TEXT"><a id="7857315"><strong>буюртмачи</strong> — дори воситасини ишлаб чиқариш, сифат назоратини ўтказиш ва (ёки) қадоқлаш учун бошқа ишлаб чиқарувчи фармацевтика ташкилотини жалб қилган ҳолда ишлаб чиқарилган дори воситасининг рўйхатдан ўтказилганлик гувоҳномасига эгалик қилиш ҳуқуқига эга бўлган юридик шахс;</a></div><div class="ACT_TEXT"><a id="7857317"><strong>женерик дори воситаси — </strong>оригинал (патентланган) дори воситасининг фаол моддаси билан сифат ва миқдорий жиҳатдан бир хил таркибга, дори шаклига эга бўлган, лекин патент муддати тугагандан сўнг ишлаб чиқарилган дори воситаси бўлиб, хавфсизлиги, таъсир кучи, хоссалари, қўлланилиш соҳаси ҳамда биоэквивалентлиги оригинал дори воситасига нисбатан тасдиқланган дори воситаси. Фаол модданинг турли тузлари, эфирлари, изомерлари, изомерлар аралашмалари, комплекслари ёки ҳосилалари хавфсизлиги ва самарадорлиги жиҳатидан сезиларли фарқ қилмаса, бир хил фаол модда сифатида эътироф этилади. Оғиз орқали қабул қилиш учун мўлжалланган ва таъсир этувчи моддаси тез ажраладиган турли дори шакллари биокираолишликни ўрганиш доирасида бир хил дори шакли сифатида тан олинади;</a></div><div class="ACT_TEXT"><a id="7857319"><strong>гомеопатик дори воситаси</strong> — табиий моддалардан (ўсимликлар, минераллар, ҳайвон маҳсулотлари) тайёрланиб, таъсирини кучайтириш мақсадида гомеопатик технология ёрдамида тайёрланадиган дори воситаси;</a></div><div class="ACT_TEXT"><a id="7857320"><strong>гувоҳнома эгаси</strong> — дори воситасининг рўйхатдан ўтказилганлик гувоҳномасига эгалик қилиш ҳуқуқига эга бўлган, дори воситасининг хавфсизлиги, сифати ва самарадорлиги учун жавоб берувчи, дори воситаларининг ишлаб чиқувчиси, ишлаб чиқарувчиси ёки буюртмачиси бўлган ваколатли юридик шахс;</a></div><div class="ACT_TEXT"><a id="7857322"><strong>дори воситалари</strong> — касалликлар профилактикаси, уларга ташхис қўйиш ва уларни даволаш, шунингдек, одам организмининг ҳолати ва функцияларини ўзгартириш учун тиббиёт амалиётида қўлланилишига рухсат этилган дори моддалари (субстанциялар) ва ёрдамчи моддалар асосида олинган воситалар, дори моддалари (субстанциялар), дори препаратлари;</a></div><div class="ACT_TEXT"><a id="7857323"><strong>дори моддалари (субстанциялар)</strong> — фармакологик, иммунологик ёки метаболик фаолликка эга бўлган ёхуд ташхис қўйиш мақсади учун фойдаланиладиган, тиббиёт амалиётида қўлланилишига рухсат этилган, келиб чиқиши табиий ёки синтетик моддалар;</a></div><div class="ACT_TEXT"><a id="7857325"><strong>доривор ўсимлик хомашёси</strong> — дори воситаларини ишлаб чиқариш ва тайёрлаш учун фойдаланиладиган, таркибида биологик фаол моддалар бўлган ўсимликлар ёки уларнинг қисмлари;</a></div><div class="ACT_TEXT"><a id="7857326"><strong>дори воситасининг </strong><strong>ишлаб чиқариш майдони</strong> — дори воситаси ишлаб чиқаришнинг тўлиқ жараёни ва (ёки) унинг айрим босқичларини амалга ошириш учун мўлжалланган «Зарур ишлаб чиқариш амалиёти (GMP)» талаблари жорий этилган ва лицензияга ёки унга тенглаштирилган ҳужжатга эга юридик шахснинг ишлаб чиқариш ва ёрдамчи бинолари мажмуаси;</a></div><div class="ACT_TEXT"><a id="7857328"><strong>корхона фармакопея мақоласи</strong> — муайян ишлаб чиқарувчининг дори воситаси, доривор ўсимлик хом ашёси ёки ёрдамчи модданинг сифатига доир талабларни белгиловчи ҳужжат;</a></div><div class="ACT_TEXT"><a id="7857330"><strong>оригинал дори воситаси</strong> — сифати, самарадорлиги ва хавфсизлиги клиник олди ва клиник тадқиқотлар натижалари асосида тасдиқланган, дунё фармацевтика бозорида биринчи бўлиб рўйхатга олинган янги таъсир этувчи моддага ёки моддаларга эга бўлган дори воситаси;</a></div><div class="ACT_TEXT"><a id="7857333"><strong>радиофармацевтик дори препарати</strong> — дори моддаси (субстанция) сифатида ёки унинг бир қисми сифатида қўлланилиши учун тайёр ҳолда бир ёки бир неча радионуклидлар (радиоактив изотоплар) сақловчи дори препарати;</a></div><div class="ACT_TEXT"><a id="7857337"><strong>рецепт</strong> — шифокорнинг фармацевтик маълумотга эга бўлган мутахассисга дори препаратини тайёрлаш ва (ёки) бериш ҳамда унинг қўлланилиш усули тўғрисидаги ёзма ва (ёки) электрон кўрсатмаси;</a></div><div class="ACT_TEXT"><a id="7857339"><strong>рўйхатдан ўтказилганлик гувоҳномаси</strong> — дори воситасининг давлат рўйхатидан ўтказилганлигини ва унинг Соғлиқни сақлаш вазирлиги томонидан тиббиёт амалиётида қўлланилишига рухсат берилганини тасдиқловчи ҳужжат;</a></div><div class="ACT_TEXT"><a id="7857340"><strong>рўйхатдан ўтказиш ҳужжатлари</strong> — ариза берувчи томонидан дори воситасининг сифати, самарадорлиги, безарарлиги ва бошқа маълумотларни ўз ичига олган рўйхатдан ўтказиш, рўйхатдан ўтказилганлик гувоҳномасининг амал қилиш муддатини узайтириш, дори воситасини рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш мақсадида Марказга тақдим этиладиган ҳужжатлар;</a></div><div class="ACT_TEXT"><a id="7857341"><strong>сифатни таъминлаш бўйича шартнома — </strong>шартнома асосида ва (ёки) технологиялар трансфери орқали дори воситасини ишлаб чиқаришда юридик шахслар ўртасидаги дори воситасининг сифатига тааллуқли ҳуқуқ ва мажбуриятларини белгиловчи ҳужжат;</a></div><div class="ACT_TEXT"><a id="7857342"><strong>спецификация</strong> — дори воситасининг сифат кўрсаткичлари, сифат назорати усуллари ва уларга ҳаволалар, сифат кўрсаткичлари меъёрлари ва уни ўрганиш мезонлари рўйхати;</a></div><div class="ACT_TEXT"><a id="7857343"><strong>технологиялар трансфери</strong> — дори воситасини яратиш ва (ёки) ишлаб чиқариш технологик жараёнларини, маълумотлари ва тажрибаларини, шу жумладан, дори воситасининг сифат ва миқдорий таркибини ўзгартирмаган ҳолда бир фармацевтика ташкилотидан бошқа фармацевтика ташкилотининг ишлаб чиқариш майдонига кўчириш, «in bulk» маҳсулотлари бундан мустасно;</a></div><div class="ACT_TEXT"><a id="7857345"><strong>фармакологик воситалар</strong> — муайян дори шаклига, клиник олди тадқиқотларда аниқланган фармакологик фаолликка ва хавфсизликка эга бўлган, клиник тадқиқот объектлари бўлган модда ёки моддалар аралашмаси;</a></div><div class="ACT_TEXT"><a id="7857348"><strong>фармацевтика ташкилоти</strong> — дори воситасининг хавфсизлиги, сифати ва самарадорлиги учун жавоб берувчи, дори воситаларининг ишлаб чиқувчиси, ишлаб чиқарувчиси ёки буюртмачиси бўлган ваколатли юридик шахс;</a></div><div class="ACT_TEXT"><a id="7857349"><strong>халқаро патентланмаган ном</strong> — дори моддаларининг (субстанциялар) Жаҳон соғлиқни сақлаш ташкилоти (кейинги ўринларда — ЖССТ) томонидан тавсия этилган номи;</a></div><div class="ACT_TEXT"><a id="7857350"><strong>шартнома асосида ишлаб чиқариш — </strong>бир<strong> </strong>фармацевтика ташкилоти қувватларидаги технологияларни ўзгартирмаган ҳолда, унинг рўйхатдан ўтказилган дори воситаларини буюртмага кўра бошқа фармацевтика ташкилоти учун шартнома асосида ишлаб чиқариш;</a></div><div class="ACT_TEXT"><a id="7857352"><strong>ҳужайра технологияси асосида ишлаб чиқарилган биотехнология дори воситалари</strong> — тирик ҳужайралардан ёки уларнинг маҳсулотларидан фойдаланган ҳолда яратиладиган, биологик хоссалари, физиологик функциялари ёки тузилиши тиббиёт амалиётида қўллаш мақсадида ўзгартирилган биологик дори воситалари.</a></div><div class="ACT_TEXT"><a id="7857353">3. Дори воситалари давлат рўйхатидан умумий тартибда ва тан олиш йўли билан ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857355">Бунда қуйидаги хорижий ташкилотлар томонидан рўйхатдан ўтказилган дори воситалари Ўзбекистон Республикасида тан олиш орқали давлат рўйхатидан ўтказилади:</a></div><div class="ACT_TEXT"><a id="7857356">Жаҳон соғлиқни сақлаш ташкилоти рўйхатига киритилган тартибга солувчи органлар (WHO Listed Authorities);</a></div><div class="ACT_TEXT"><a id="7857358">Жаҳон соғлиқни сақлаш ташкилотининг Глобал таққослаш воситаси (Global Benchmarking Tool) бўйича 4-даражали етукликка (Maturity Level 4) эга бўлган тартибга солувчи органлар.</a></div><div class="ACT_TEXT"><a id="7857359">4. Дори воситаларини рўйхатдан ўтказиш ва гувоҳнома бериш Марказ томонидан ушбу Низомга <a href="javascript:scrollText(7858081)">1-иловага</a> мувофиқ схема бўйича амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7857361">5. Қуйидагилар рўйхатдан ўтказилади:</a></div><div class="ACT_TEXT"><a id="7857364">дори воситалари (бундан дори воситаларини ишлаб чиқаришда қўлланиладиган дори моддалари (субстанциялар) мустасно);</a></div><div class="ACT_TEXT"><a id="7857366">Ўзбекистон Республикасида рўйхатдан ўтказилган дори воситаларининг янги комбинациялари;</a></div><div class="ACT_TEXT"><a id="7857367">илгари Ўзбекистон Республикасида рўйхатдан ўтказилган, лекин бошқача дори шаклларида, дозаларда ёки бошқа ишлаб чиқарувчи томонидан ишлаб чиқарилган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857369">илгари Ўзбекистон Республикасида рўйхатдан ўтказилган, тури (аутологик, аллоген, комбинацияланган), сифат таркиби ва (ёки) миқдорий таркиби (ёрдамчи моддалар таркиби бундан мустасно), ҳужайра линияси (ҳужайра линиялари)нинг биологик хусусиятлари ва бошқа хусусиятлари ўзгарган ҳужайра технологияси асосида ишлаб чиқарилган биотехнология дори воситалари.</a></div><div class="ACT_TEXT"><a id="7857371">6. Таркибида турли дори моддалари бўлган дори воситаларини бир хилдаги савдо номи остида рўйхатдан ўтказишга йўл қўйилмайди. Бир ишлаб чиқарувчи томонидан турли савдо номлари остида шартнома ва технологиялар трансфери асосида ишлаб чиқариладиган таркиби бир хил дори моддаларидан иборат бўлган дори воситаларини рўйхатдан ўтказишга йўл қўйилади.</a></div><div class="ACT_TEXT"><a id="7857373">Бунда гувоҳнома эгаси буюртмачи ёки технологиялар трансфери эгаси бўлиши мумкин.</a></div><div class="BY_DEFAULT"><a id="8082513"></a></div><div class="ACT_TEXT"><a id="8082515">6<sup>1</sup>. Маҳаллий ишлаб чиқарувчиларнинг рўйхатдан ўтказилган таркиби бир хил дори моддаларидан иборат бўлган дори воситалари турли савдо номлари остида шартнома асосида ишлаб чиқарилганда лаборатория синовларисиз тан олиш йўли билан рўйхатдан ўтказилади.</a></div><div class="ACT_TEXT"><a id="8082516">Бунда шартнома асосида ишлаб чиқариладиган дори воситаси асосий дори воситасига нисбатан таъсир этувчи модданинг (субстанция) ишлаб чиқарувчиси, ёрдамчи моддалар таркиби, бирламчи қадоқнинг материаллари ва контейнер-ёпиш тизими, сифат назорати усуллари, меъёрлари ва ишлаб чиқариш технологияси билан ўзгаришсиз мос бўлиши лозим.</a></div><div class="ACT_TEXT"><a id="8082517">Ўзгаришлар фақат савдо номи, иккиламчи қадоқ дизайни ва йўриқнома дизайнида бўлишига йўл қўйилади.</a></div><div class="ACT_TEXT"><a id="8082518">Ушбу шартлар бажарилмаган тақдирда дори воситаси умумий тартибда рўйхатдан ўтказилади.</a></div><div class="ACT_TEXT"><a id="8082519">Мазкур тартибда рўйхатдан ўтказилган дори воситасининг биринчи саноат серияси (сериялари) мажбурий тарзда постмаркетинг назоратидан ўтказилади, мазкур банднинг тўртинчи хатбошиси бундан мустасно.</a></div><div class="ACT_TEXT"><a id="7857374">7. Қуйидагиларни рўйхатдан ўтказиш талаб этилмайди:</a></div><div class="ACT_TEXT"><a id="7857375">дори воситаларини ишлаб чиқариш мақсадида қўлланиладиган субстанциялар;</a></div><div class="ACT_TEXT"><a id="7857376">дорихоналарда тайёрланадиган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857377">бевосита тиббиёт муассасаларида тайёрланадиган радиофармацевтик дори препаратлари;</a></div><div class="ACT_TEXT"><a id="7857378">илмий-тадқиқот ишлари учун олиб кириладиган, клиник олди тадқиқотлар, клиник тадқиқотлар ўтказиш, кўргазмаларда, ярмаркаларда, халқаро анжуманларда намойиш этиш учун мўлжалланган дори воситаси;</a></div><div class="ACT_TEXT"><a id="7857379">экспорт учун мўлжалланган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857380">суяк илиги ўзак ҳужайралари;</a></div><div class="ACT_TEXT"><a id="7857381">индивидуал тиббий кўрсатмани бажариш мақсадида айрим беморлар учун тиббиёт муассасаси томонидан махсус ишлаб чиқарилган ва шу муассасада қўлланиладиган ҳужайра технологияси асосидаги биотехнология воситалари.</a></div><div class="ACT_TEXT"><a id="7857382">Бунда дори воситаларини ишлаб чиқариш мақсадида қўлланиладиган субстанциялар, экспорт учун мўлжалланган дори воситалари ариза берувчи хоҳишига кўра рўйхатдан ўтказилиши мумкин.</a></div><div class="ACT_TEXT"><a id="7857384">8. Орфан дори воситалари импорти, ўта хавфли инфекциялар, шунингдек, Ўзбекистон Республикаси Соғлиқни сақлаш вазирлигининг буюртмаси бўйича эпидемиологик жиҳатдан хавф туғдирадиган инфекциялар профилактикасида, уларга ташхис қўйишда ҳамда уларни даволашда қўлланиладиган, импорт қилинадиган дори воситалари импорти давлат рўйхатидан ўтказилмаган ҳолда амалга оширилиши мумкин.</a></div><div class="ACT_TEXT"><a id="7857385">Ташқи беғараз кўмак ҳамда инсонпарварлик ёрдами сифатида олиб кирилаётган дори воситалари давлат рўйхатидан ўтказилмасдан, Ўзбекистон Республикаси ҳудудига киритилишига ва улардан фойдаланишга рухсат берилади. Бунда ушбу дори воситаларининг Ўзбекистон Республикаси ҳудудига олиб кирилишига ва улардан фойдаланишга Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан тегишли ижобий хулоса берилиши лозим.</a></div><div class="ACT_TEXT"><a id="7857386">9. Қуйидаги дори воситалари устуворлик асосида рўйхатдан ўтказилади:</a></div><div class="ACT_TEXT"><a id="7857387">республикада рўйхатдан ўтказилган аналоги мавжуд бўлмаган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857388">орфан дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857389">Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан берилган талаб асосида ички бозорда эҳтиёжи юқори бўлган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857390">оригинал дори воситасининг биринчи аналоги.</a></div><div class="ACT_TEXT"><a id="7857391">10. Дори воситалари қуйидаги йўллар орқали ишлаб чиқарилади:</a></div><div class="ACT_TEXT"><a id="7857392">бевосита фармацевтика ташкилотида ишлаб чиқариш;</a></div><div class="ACT_TEXT"><a id="7857393">фармацевтика ташкилоти қувватларидаги технологияларни ўзгартирмаган ҳолда, рўйхатдан ўтказилган дори воситаларини бошқа фармацевтика ташкилотининг буюртмаси бўйича шартнома асосида ишлаб чиқариш;</a></div><div class="ACT_TEXT"><a id="7857394">фармацевтика ташкилотига бошқа фармацевтика ташкилотининг рўйхатдан ўтказилган дори воситасининг технологик жараёнини кўчириш (технологиялар трансфери) орқали ишлаб чиқариш.</a></div><div class="ACT_TEXT"><a id="7857395">Шартнома ва технологиялар трансфери асосида ишлаб чиқарилган дори воситаларининг хавфсизлиги, сифати ҳамда самарадорлиги учун жавобгарлик буюртмачи, технологиялар трансфери эгаси ва ишлаб чиқарувчи зиммасига юкланади.</a></div><div class="ACT_TEXT"><a id="7857396">Бундай ҳолатларда ишлаб чиқариладиган дори воситасини Ўзбекистон Республикасида рўйхатдан ўтказиш учун буюртмачи ёки технологиялар трансфери эгаси ва ишлаб чиқарувчи фармацевтика ташкилотининг ишлаб чиқариш майдонлари «Зарур ишлаб чиқариш амалиёти (GMP)»нинг миллий талабларига мувофиқлик тўғрисида сертификатга эга бўлиши талаб этилади (тан олиш орқали давлат рўйхатидан ўтказиладиган, ЖССТ томонидан қайта малакаланган дори воситаларининг ишлаб чиқариш майдонлари бундан мустасно). Бунда технологиялар трансферини қабул қилган фармацевтика ташкилотида ўрнатилган тартибда йилига камида бир маротаба «Зарур ишлаб чиқариш амалиёти (GMP)»нинг миллий талаблари бўйича инспекция назорати ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857397">Дори воситасини ишлаб чиқувчиси олий таълим муассасалари ва илмий-тадқиқот ташкилотлари (ишлаб чиқарувчилар бундан мустасно) бўлган тақдирда, уларнинг «Зарур ишлаб чиқариш амалиёти (GMP)» миллий талабларига мувофиқлик тўғрисида сертификатга эга бўлиши талаб этилмайди.</a></div><div class="ACT_TEXT"><a id="7857398">11. Дори воситаларини давлат рўйхатидан ўтказиш натижаларига кўра амал қилиш муддати беш йил бўлган рўйхатдан ўтказилганлик гувоҳномаси берилади.</a></div><div class="ACT_TEXT"><a id="7857399">Дори воситаларини давлат рўйхатидан ўтказишда ҳамда рўйхатдан ўтказилганлик гувоҳномасининг амал қилиш муддатини узайтиришда «Зарур ишлаб чиқариш амалиёти (GMP)» Ўзбекистон Республикаси миллий талабларига мувофиқлиги тўғрисидаги сертификат талаб қилинади.</a></div><div class="ACT_TEXT"><a id="7857400">Хорижий ишлаб чиқарувчининг «Зарур ишлаб чиқариш амалиёти (GMP)» Ўзбекистон Республикаси миллий талабларига мувофиқлиги бўйича инспекциясини дори воситасининг давлат рўйхатидан ўтказиш жараёни билан бир вақтда олиб боришга рухсат берилади. Бунда дори воситаси Марказ томонидан давлат рўйхатидан ўтказилгунга қадар «Зарур ишлаб чиқариш амалиёти (GMP)» Ўзбекистон Республикаси миллий талабларига мувофиқлиги ҳақида сертификат тақдим этилиши шарт.</a></div><div class="ACT_TEXT"><a id="7857401">Давлат рўйхатидан ўтказиш тан олиш йўли билан рўйхатдан ўтказиладиган, ЖССТ томонидан қайта малакаланган дори воситалари бундан мустасно.</a></div><div class="ACT_TEXT"><a id="7857402">12. Марказ рўйхатдан ўтказиш фаолиятини ташкил этиш мақсадида маслаҳат ва коллегиал органлар тузиши мумкин.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857406">2-боб. Дори воситаларини рўйхатдан ўтказишга доир талаблар ва шартлар</a></div><div class="ACT_TEXT"><a id="7857408">13. Дори воситаларини рўйхатдан ўтказилганлик гувоҳномаси асосида тиббиёт амалиётида қўлланилишида ариза берувчи томонидан бажарилиши шарт бўлган талаблар ва шартлар қуйидагилардан иборат:</a></div><div class="ACT_TEXT"><a id="7857410">дори воситаларини рўйхатдан ўтказиш учун мурожаат қилган ариза берувчи томонидан уларнинг тиббиёт амалиётида қўлланилишида қонунчилик ҳужжатлари ва миллий техник жиҳатдан тартибга солиш соҳасидаги норматив ҳужжатлар талабларига риоя этиш;</a></div><div class="ACT_TEXT"><a id="7857411">рўйхатдан ўтказиш гувоҳномасини олиш, қайта расмийлаштириш, унинг амал қилиш муддатини узайтириш ҳамда рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш учун тақдим этиладиган маълумотларнинг тўғрилиги ва ишончлилигини таъминлаш;</a></div><div class="ACT_TEXT"><a id="7857413">дори воситаларининг сифати, хавфсизлиги ва самарадорлиги кафолатланганлигини таъминлаш;</a></div><div class="ACT_TEXT"><a id="7857414">гувоҳноманинг амал қилиш даврида ариза берувчи томонидан Марказга рўйхатдан ўтказиш ҳужжатларига ўзгартириш ёки қўшимчалар киритиш тўғрисида маълумотларни ўз вақтида тақдим этиш;</a></div><div class="ACT_TEXT"><a id="7857416">фармакопея мақолалари талабларига ҳамда дори воситаларини рўйхатдан ўтказиш ҳужжатларида келтирилган маълумотларга қатъий риоя этиш;</a></div><div class="ACT_TEXT"><a id="7857417">дори воситалари ишлаб чиқаришда «Зарур ишлаб чиқариш амалиёти (GMP)», фармаконазоратда «Зарур фармаконазорат амалиёти (GVP)» миллий талабларига риоя этиш;</a></div><div class="ACT_TEXT"><a id="7857419">дори воситаларини тиббиёт амалиётида қўлланилишида маълум бўлган ножўя таъсирлари тўғрисидаги маълумотларни Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан белгиланадиган тартибга мувофиқ Марказга тақдим этиб бориш;</a></div><div class="ACT_TEXT"><a id="7857420">дори воситасининг сифати, самарадорлиги ёки хавфсизлиги сабабли бошқа давлатларда рўйхатдан ўтказилганлик гувоҳномасининг амал қилиш муддати тўхтатиб турилганлиги, бекор қилинганлиги, муомаладан чақириб олинганлиги, гувоҳнома олиш тўғрисидаги аризаси рад этилганлиги ҳақида Марказни дарҳол хабардор қилиш;</a></div><div class="ACT_TEXT"><a id="7857422">дори воситаси давлат рўйхатидан ўтказилгандан сўнг камида уч йил ичида Ўзбекистон Республикасида муомалага киритилишини таъминлаш (маҳаллий ишлаб чиқарувчилар томонидан экспорт учун ишлаб чиқарилган дори воситалари бундан мустасно).</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857425">3-боб. Рўйхатдан ўтказиш учун зарур бўлган ҳужжатлар ва намуналар</a></div><div class="ACT_TEXT"><a id="7857430">14. Рўйхатдан ўтказиш учун ариза берувчи Марказга қуйидагиларни тақдим этади:</a></div><div class="ACT_TEXT"><a id="7857431">а) ушбу Низомга <a href="javascript:scrollText(7859679)">2-иловага</a> мувофиқ ариза;</a></div><div class="ACT_TEXT"><a id="7857432">б) ушбу Низомга <a href="javascript:scrollText(7859735)">3-иловага</a> мувофиқ ариза берувчининг электрон имзоси билан тасдиқланган дори воситаларининг халқаро талаблар (ICH CTD формати) бўйича рўйхатдан ўтказиш ҳужжатларининг электрон шакли;</a></div><div class="ACT_TEXT"><a id="7857434">в) дори воситасининг корхона фармакопея мақоласи лойиҳаси талабларига мувофиқ уч маротаба синовлар ўтказилиши учун зарур бўлган миқдордаги, сифат сертификатлари билан бирга тақдим этиладиган қолдиқ яроқлилик муддати 50 фоиздан кам бўлмаган бир саноат сериясидаги намуналари (тан олиш орқали давлат рўйхатидан ўтказиладиган, ЖССТ томонидан қайта малакаланган дори воситалари бундан мустасно);</a></div><div class="ACT_TEXT"><a id="7857436">г) тан олиш йўли билан рўйхатдан ўтказиладиган дори воситаларининг сифат сертификатлари билан бирга тақдим этиладиган бир истеъмол қадоғидаги намуналари;</a></div><div class="ACT_TEXT"><a id="7857437">д) фармакопея мақолаларига мувофиқ фаол таъсир этувчи моддаларнинг ҳамда ёт ва ўхшаш моддаларнинг фармакопея ёки референс стандарт намуналари, назорат материаллари, зарур холларда махсус реактивлар, микроорганизмлар тест-штаммлари, махсус хроматографик колонкалар, дори воситаларини ишлаб чиқарувчининг махсус сарфлаш материаллари ҳамда реагентлари ва уларнинг сифатини тасдиқловчи ҳужжатлар (тан олиш йўли билан рўйхатдан ўтказиладиган дори воситалари бундан мустасно).</a></div><div class="ACT_TEXT"><a id="7857439">Давлат рўйхатидан ўтказиш учун тақдим этилган дори воситаларининг клиник тадқиқотларини ўтказишда GCP (Зарур клиника амалиёти) қоидаларига мувофиқ ариза берувчи томонидан клиник базаларга дори воситаларининг клиник тадқиқотлар ўтказиш учун зарур бўлган, қонунчиликда белгиланган ҳужжатлар ва намуналар тақдим этилади.</a></div><div class="ACT_TEXT"><a id="7857441">Бир тайёр дори воситасини ишлаб чиқаришда бир нечта ишлаб чиқарувчининг дори моддаси (субстанцияси) қўлланилган ҳолларда, ҳар бир ишлаб чиқарувчининг дори моддаси (субстанцияси)дан ишлаб чиқарилган намуналар, ҳар бир ишлаб чиқарувчининг дори моддасига (субстанциясига) тегишли, мазкур Низомга 3-илова 3-бўлимининг <a href="javascript:scrollText(7860001)">3.2.S-бандида</a> санаб ўтилган ҳужжатлар тақдим этилиши лозим.</a></div><div class="ACT_TEXT"><a id="7857442">Мазкур Низомга 3-илова 1-бўлимининг <a href="javascript:scrollText(7859789)">1.3</a> ва <a href="javascript:scrollText(7859843)">1.10-бандларида</a> санаб ўтилган хориждан олинган расмий ҳужжатлар апостиль муҳрли ёки консуллик томонидан тасдиқланган бўлиши шарт.</a></div><div class="ACT_TEXT"><a id="7857444">Ариза берувчидан ушбу бандда назарда тутилмаган ҳужжатлар ва намуналар тақдим этилишини талаб қилишга йўл қўйилмайди.</a></div><div class="ACT_TEXT"><a id="7857445">15. Рўйхатдан ўтказиш учун зарур бўлган ҳужжатлар Марказнинг ахборот тизимига (кейинги ўринларда — ахборот тизими) ушбу Низомнинг <a href="javascript:scrollText(7859735)">3-иловасида</a> назарда тутилган кетма-кетликда ҳар бирини алоҳида юклаган ва ариза берувчининг электрон рақамли имзоси билан тасдиқланган ҳолда киритилади.</a></div><div class="ACT_TEXT"><a id="7857447">Электрон рақамли имзо ариза берувчи ёки унинг номидан фаолият юритувчи юридик шахснинг фармацевтика, тиббиёт, кимё ёки биология йўналишида олий маълумотга эга бўлган ишончли вакилига расмийлаштирилган бўлиши шарт.</a></div><div class="ACT_TEXT"><a id="7857448">16. Дори воситалари намуналари ариза берувчи томонидан сақлаш ва ташиш шароитлари таъминланган ҳолда, бевосита Марказга тақдим этилади, мазкур Низомнинг 22-банди «б» кичик банди <a href="javascript:scrollText(7857557)">тўртинчи хатбошисида</a> назарда тутилган ҳолатлар бундан мустасно.</a></div><div class="ACT_TEXT"><a id="7857451">Тақдим этиладиган дори воситаси намунаси бошқа савдо номида бўлиши мумкин. Бунда намуналар аризада кўрсатилган ишлаб чиқариш майдонида, таркибда, қадоқларда ва технология асосида ишлаб чиқарилган бўлиши шарт.</a></div><div class="ACT_TEXT"><a id="7857452">17. Таркибида янги кимёвий моддалар мавжуд бўлган дори воситасини давлат рўйхатидан ўтказишда тақдим этилган дори воситасининг рўйхатдан ўтказиш ҳужжатларидаги мавжуд махфий ахборот дори воситаси давлат рўйхатидан ўтказилган кундан эътиборан олти йил мобайнида ариза берувчининг розилигисиз ошкор қилиниши мумкин эмас.</a></div><div class="ACT_TEXT"><a id="7857454">Марказ рўйхатдан ўтказиш ҳужжатларидаги махфий маълумотларнинг ошкор қилиниши учун жавоб беради. Рўйхатдан ўтказиш ҳужжатларидаги махфий маълумотлар ариза берувчи томонидан алоҳида кўрсатилиши мумкин.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857458">4-боб. Аризани кўриб чиқиш, рўйхатдан ўтказиш ёки рўйхатдан ўтказишни рад этиш тўғрисида қарор қабул қилиш</a></div><div class="ACT_TEXT"><a id="7857459">18. Дори воситаларини рўйхатдан ўтказиш тўғрисидаги аризани кўриб чиқиш учун йиғим ундирилади ҳамда унинг миқдорлари Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан тасдиқланади.</a></div><div class="ACT_TEXT"><a id="7857461">Йиғим суммаси Марказнинг шахсий ғазна ҳисобварағига ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857463">Ариза берувчи берган аризасидан воз кечган тақдирда ва дори воситасини рўйхатдан ўтказиш рад этилганда, тўланган йиғим суммаси қайтарилмайди.</a></div><div class="ACT_TEXT"><a id="7857464">19. Рўйхатдан ўтказиш тўғрисидаги ариза Марказ томонидан қуйидаги муддатларда кўриб чиқилади:</a></div><div class="ACT_TEXT"><a id="7857470"><strong>30 кун</strong> — бир марталик бир йил муддатга рўйхатдан ўтказиладиган, эпидемиологик жиҳатдан хавф туғдирадиган инфекциялар эпидемияси ва пандемияси даврида қўлланиладиган вакциналар;</a></div><div class="ACT_TEXT"><a id="7857472"><strong>45 кун</strong> — дори моддалари (субстанциялар);</a></div><div class="ACT_TEXT"><a id="7857474"><strong>60 кун — </strong>тан олиш йўли билан рўйхатдан ўтказиладиган дори воситалари, ЖССТ томонидан қайта малакаланган (prequalification) дори препаратлари;</a></div><div class="ACT_TEXT"><a id="7857477"><strong>210 кун — </strong>умумий тартибда рўйхатдан ўтказиладиган дори воситалари.</a></div><div class="ACT_TEXT"><a id="7857478">Қуйидагилар рўйхатдан ўтказиш тўғрисидаги аризани кўриб чиқиш муддатларига киритилмайди:</a></div><div class="ACT_TEXT"><a id="7857480">бирламчи экспертиза натижалари бўйича аризага илова қилинган рўйхатдан ўтказиш ҳужжатлари ва намуналарида аниқланган камчиликларни бартараф этиш учун бериладиган 45 кунлик муддат;</a></div><div class="ACT_TEXT"><a id="7857482">хорижий сертификат ва (ёки) гувоҳномаларнинг ҳаққонийлигини очиқ манбалар орқали текшириш имкони бўлмаганда, ваколатли органга юборилган расмий сўровга жавоб берилиши учун кетган муддат;</a></div><div class="ACT_TEXT"><a id="7857484">рўйхатдан ўтказиш учун зарур бўлган ҳужжатларда, дори воситалари намуналарида ихтисослаштирилган экспертиза натижалари бўйича аниқланган камчиликларни бартараф этиш учун бериладиган 90 кунлик муддат;</a></div><div class="ACT_TEXT"><a id="7857486">Ўзбекистон Республикасида клиник тадқиқотлари ўтказилмаган женерик дори воситаларининг клиник тадқиқотларини ўтказишнинг бевосита бир йилдан ошмайдиган, оригинал дори воситаларининг клиник тадқиқотларини ўтказишнинг уч йилдан ошмайдиган муддатлари;</a></div><div class="ACT_TEXT"><a id="7857488">Дори воситаларини ишлаб чиқариш шароитларининг «Зарур ишлаб чиқариш амалиёти (GMP)» миллий талабларига мувофиқлигини баҳолаш учун кетган муддат.</a></div><div class="ACT_TEXT"><a id="7857490">20. Дори воситаларининг экспертизаси дори воситаларининг сифати, хавфсизлиги ва самарадорлигини ҳамда дори воситаларининг «фойда — хавф» нисбатини илмий баҳолаш учун ўтказилади ва қуйидагиларни ўз ичига олади:</a></div><div class="ACT_TEXT"><a id="7857493">а) ариза берувчи томонидан дори воситасининг рўйхатдан ўтказиш йиғмажилдида тақдим этилган ҳужжатлар ва маълумотларни илмий комиссиялар ёки мутахассислар томонидан батафсил баҳолаш;</a></div><div class="ACT_TEXT"><a id="7857494">б) сифат бўйича норматив ҳужжат талабларига мувофиқлик юзасидан лаборатория синовларини ўтказиш ва сифатни назорат қилишнинг таҳлилий услубиётларини верификация қилиш;</a></div><div class="ACT_TEXT"><a id="7857495">в) дори воситасини баҳолаш жараёни якунида илмий комиссия маҳсулотнинг барча жиҳатларини, айниқса унинг «фойда — хавф» нисбатини инобатга олган ҳолда эксперт хулосаси тайёрлаш. Бунда комиссия томонидан тайёрланган эксперт хулосаси дори воситасини рўйхатдан ўтказиш бўйича қарор қабул қилиш учун асослардан бири бўлади.</a></div><div class="ACT_TEXT"><a id="7857496">Қуйидагилар рўйхатдан ўтказишда дори воситаларини экспертизадан ўтказишнинг асосий принциплари ҳисобланади:</a></div><div class="ACT_TEXT"><a id="7857497">а) экспертларнинг мустақиллиги ва улар томонидан касбий фаолиятни амалга оширишда ҳуқуқий ҳимояланганлиги;</a></div><div class="ACT_TEXT"><a id="7857498">б) экспертиза объектлари тадқиқотларининг илмий ёндашуви, тўлиқлиги, ҳар томонламалиги ва холислиги, ҳужжатлар билан тасдиқланган мақбуллик мезонларига мувофиқ экспертиза натижаларининг асосланганлигини таъминлаш;</a></div><div class="ACT_TEXT"><a id="7857500">в) эксперт ташкилотлари ва экспертларнинг малакаси ва юқори профессионал даражаси.</a></div><div class="ACT_TEXT"><a id="7857501">21. Дори воситаларини рўйхатдан ўтказиш талаб ва шартларининг бажарилганлиги Марказ томонидан қуйидагилар орқали баҳоланади:</a></div><div class="ACT_TEXT"><a id="7857503">дори воситаларининг рўйхатдан ўтказиш ҳужжатлари экспертизаси;</a></div><div class="ACT_TEXT"><a id="7857504">дори воситалари ишлаб чиқариш шароитларининг «Зарур ишлаб чиқариш амалиёти (GMP)» миллий талабларига мувофиқлигини баҳолаш натижаларини ўрганиш;</a></div><div class="ACT_TEXT"><a id="7857505">дори воситалари намуналарининг лаборатория синовлари;</a></div><div class="ACT_TEXT"><a id="7857507">дори воситаларининг сифати, хавфсизлиги ва самарадорлигини ҳамда уларнинг «фойда — хавф» нисбатини илмий баҳолаш натижалари;</a></div><div class="ACT_TEXT"><a id="7857508">таркибида гиёҳвандлик воситалари, психотроп моддалар ва прекурсорлар бўлган дори воситалари ҳужжатлари экспертизаси.</a></div><div class="ACT_TEXT"><a id="7857511">22. Рўйхатдан ўтказиш Марказ томонидан ушбу Низомга <a href="javascript:scrollText(7858081)">1-иловада</a> кўрсатилган муддатларда қуйидаги тартибда амалга оширилади:</a></div><div class="ACT_TEXT"><a id="7857512">а) бирламчи (дастлабки) экспертиза:</a></div><div class="ACT_TEXT"><a id="7857513">ариза қабул қилингандан сўнг ариза ва унга илова қилинган ҳужжатлар ҳамда дори воситаларининг намуналари бирламчи (дастлабки) экспертизадан ўтказилади. Бунда дори воситасининг рўйхатдан ўтказиш учун тақдим қилинган ҳужжатларнинг тўлиқлиги ва тўғри расмийлаштирилганлиги, лаборатория синовларини ўтказиш учун тақдим этилган дори воситалари намуналари ва стандарт намуналарнинг тўлиқлиги ва тўғрилиги текширилади;</a></div><div class="ACT_TEXT"><a id="7857514">тақдим этилган хорижий сертификат ва (ёки) гувоҳномалар уларни берган ваколатли органнинг расмий рўйхатларидан (веб-сайтлари) ҳаққонийлиги текширилади, хорижий сертификат ва (ёки) гувоҳномаларнинг ҳаққонийлигини очиқ манбалар орқали текшириш имкони бўлмаганда, барча расмий ҳужжатлар апостиль муҳрли ёки консуллик томонидан тасдиқланган бўлиши шарт. Зарур ҳолларда, Марказ хориждаги ваколатли органга расмий сўров юборади;</a></div><div class="ACT_TEXT"><a id="7857515">дори воситаларида интеллектуал мулк объектларига (кейинги ўринларда — ИМО) бўлган ҳуқуқларга риоя этилганлиги тўғрисида интеллектуал мулк соҳасидаги ваколатли орган хулосаси ўрганилади;</a></div><div class="ACT_TEXT"><a id="7857516">бирламчи (дастлабки) экспертиза ҳамда дори воситаларида ИМОга бўлган ҳуқуқларга риоя этилганлиги юзасидан ўрганиш натижалари асосида хулоса расмийлаштирилади.</a></div><div class="ACT_TEXT"><a id="7857517">Дори воситасининг рўйхатдан ўтказиш ҳужжатлари ва намуналарининг бирламчи экспертизаси натижаси асосида эксперт хулосаси расмийлаштирилади.</a></div><div class="ACT_TEXT"><a id="7857519">Қуйидаги ҳолатларда аризани рад этиш тўғрисида хулоса расмийлаштирилади:</a></div><div class="ACT_TEXT"><a id="7857521">мазкур Низомнинг <a href="javascript:scrollText(7857430)">14-бандида</a> назарда тутилган ҳужжатлар ва намуналар тўлиқ бўлмаган ҳажмда тақдим этилганда;</a></div><div class="ACT_TEXT"><a id="7857522">тақдим этилган ҳужжатлар ва намуналарда маълумотларнинг ишончсиз, нотўғри ёки ёлғон эканлиги аниқланганда;</a></div><div class="ACT_TEXT"><a id="7857524">дори воситаларига нисбатан ИМОга бўлган ҳуқуқларнинг бузилганлиги тўғрисида интеллектуал мулк соҳасидаги ваколатли органнинг хулосаси мавжуд бўлганда;</a></div><div class="ACT_TEXT"><a id="7857527">технология трансфери эгаси томонидан технология трансфери амалга оширилганлигини тасдиқловчи ижобий ҳисоботи ва хулосаси мавжуд бўлмаганда.</a></div><div class="ACT_TEXT"><a id="7857529">Аризанинг рад этилиши тўғрисидаги хабарнома камчиликларни аниқ кўрсатган ҳолда ҳамда уларни бартараф этиш учун 45 кунлик муддат билан ахборот тизими орқали ариза берувчига юборилади.</a></div><div class="ACT_TEXT"><a id="7857530">Камчиликлар 45 кунлик муддатда бартараф этилмаган тақдирда, Марказ томонидан рўйхатдан ўтказишни рад этиш тўғрисида қарор қабул қилинади ва ариза берувчи ахборот тизими орқали хабардор қилинади.</a></div><div class="ACT_TEXT"><a id="7857532">Аризани рад этиш юзасидан қарор қабул қилинганлиги тўғрисидаги маълумот юборилгандан кейин берилган ариза янгидан берилган ҳисобланади ва Марказ томонидан умумий асосларда кўриб чиқилади.</a></div><div class="ACT_TEXT"><a id="7857535">Бирламчи экспертизанинг ижобий хулосасидан сўнг, дори воситасининг лаборатория синовлари, ихтисослаштирилган экспертизаси бир вақтнинг ўзида олиб борилади;</a></div><div class="ACT_TEXT"><a id="7857537">б) лаборатория синовлари:</a></div><div class="ACT_TEXT"><a id="7857554">дори воситалари намуналарининг корхона фармакопея мақолалари талабларига мувофиқлигини аниқлаш бўйича ўтказилган лаборатория синовлари натижалари асосида синов баённомалари расмийлаштирилади, бунда дори воситаларининг сифат назоратини амалга оширишда Ўзбекистон Республикаси Давлат фармакопеясининг талаблари устувор ҳисобланади;</a></div><div class="ACT_TEXT"><a id="7857556">синов усуллари Ўзбекистон Республикасининг Давлат фармакопеясида келтирилмаган ҳолатларда дунёнинг эътироф этилган фармакопеялари синов усулларини қўллаш Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан белгиланади;</a></div><div class="ACT_TEXT"><a id="7857557">дори воситалари намуналарининг синовларини ўтказиш учун зарур ўлчов, синов воситалари ҳамда синов шароитлари Ўзбекистон Республикасида мавжуд бўлмаган ҳолларда, Марказ томонидан фармакопея мақолалари талабларидан келиб чиқиб, мавжуд муқобил усулларни ишлаб чиқиш учун кўрсатмалар ва талаблар белгилаб берилади (биологик дори воситалари бундан мустасно) ёки синовлар хорижий ишлаб чиқарувчининг синов лабораториясида ёхуд бошқа хорижий лабораторияларда Марказ мутахассислари иштирокида ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857559">Қуйидагилар лаборатория синовларидан ўтказилмайди:</a></div><div class="ACT_TEXT"><a id="7857561">ЖССТ томонидан қайта малакаланган (prequalification) ЖССТ билан ҳамкорликда рўйхатдан ўтказиладиган дори препаратлари;</a></div><div class="ACT_TEXT"><a id="7857563">тан олиш йўли билан рўйхатдан ўтказиладиган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857566">в) ихтисослаштирилган экспертиза:</a></div><div class="ACT_TEXT"><a id="7857581">лаборатория синовлари баённомалари ҳамда ушбу Низомга <a href="javascript:scrollText(7859735)">3-иловага</a> мувофиқ тақдим этилган ҳужжатларнинг рўйхатдан ўтказиш талаб ва шартларига мувофиқлиги мустақил экспертлардан ташкил топган илмий комиссияларнинг асосланган хулосалари асосида экспертизадан ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857583">Бунда илмий комиссияларнинг тегишли йўналишлар бўйича фаолиятини юритиш тартиби, комиссия таркиби ва уларга қўйиладиган малака талаблари Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан белгиланади;</a></div><div class="ACT_TEXT"><a id="7857588">илмий баҳолаш жараёни дори воситасини рўйхатдан ўтказиш учун тақдим этилган ҳужжатлар ва лаборатория синови натижаларининг илмий тамойилларга асосланган ҳолда мустақил мутахассислардан иборат комиссиялар томонидан баҳоланиши орқали амалга оширилади;</a></div><div class="ACT_TEXT"><a id="7857590">ариза берувчи фармакопея мақолаларининг Ўзбекистон Республикаси Давлат фармакопеяси, хорижий эътироф этилган фармакопеялар талабларига мувофиқлиги юзасидан экспертизадан ўтказилади;</a></div><div class="ACT_TEXT"><a id="7857591">зарур ҳолларда, дори воситалари намуналари ариза берувчининг фармакопея мақолалари талабларига мувофиқлигини аниқлаш мақсадида қўшимча лаборатория синовларига юборилиши мумкин;</a></div><div class="ACT_TEXT"><a id="7857602">рўйхатдан ўтказиш ҳужжатларидаги маълумотлар таҳлили ва экспертизаси асосида дори воситасининг хавфсизлиги, сифати ва самарадорлиги ҳамда «фойда-хавф» нисбати баҳоланади, шу жумладан, дори воситаси намунаси лаборатория синовлари натижалари, ишлаб чиқариш шароитларининг «Зарур ишлаб чиқариш амалиёти (GMP)» миллий талабларига мувофиқлиги юзасидан ўтказилган инспекция натижалари тўғрисидаги ҳисобот таҳлили (мавжуд бўлганда) ҳамда дори воситаси таркибидаги фаол моддалар комбинациясининг мақсадга мувофиқлиги баҳоланади;</a></div><div class="ACT_TEXT"><a id="7857605">дори воситаларини экспертизадан ўтказишда унинг рецепт билан ёки рецептсиз бериладиган дори воситалари тоифасига мансублиги аниқланади ҳамда ушбу ахборот дори воситаларининг тиббиётда қўлланилишига доир йўриқномаларда кўрсатилади;</a></div><div class="ACT_TEXT"><a id="7857607">таркибида гиёҳвандлик воситалари, психотроп моддалар ва прекурсорлар мавжуд бўлган дори воситаларини рўйхатдан ўтказишда, улар Ўзбекистон Республикасининг «Гиёҳвандлик воситалари ва психотроп моддалар тўғрисида»ги <a href="http://lex.uz/docs/86044">Қонуни</a> ва мазкур соҳадаги қонунчилик ҳужжатлари талабларига мувофиқ экспертизадан ўтказилади;</a></div><div class="ACT_TEXT"><a id="7857610">дори воситасини баҳолаш натижалари асосида ҳисобот расмийлаштирилади;</a></div><div class="ACT_TEXT"><a id="7857612">ихтисослаштирилган экспертиза давомида аниқланган камчиликлар юзасидан аризачига ахборот тизими орқали хабарнома юборилади ва уни бартараф этиш учун 90 кунлик муддат берилади;</a></div><div class="ACT_TEXT"><a id="7857614">қўшимча сўров ариза берувчи томонидан олдинги сўров бўйича тақдим этилган маълумотларда аниқланган камчиликлар бўйича юборилади;</a></div><div class="ACT_TEXT"><a id="7857616">қўшимча сўровда берилган камчиликлар бўйича ариза берувчи томонидан тўлиқ жавоб берилмаган тақдирда гувоҳномани бериш рад этилади;</a></div><div class="ACT_TEXT"><a id="7857618">Марказ директори томонидан дори воситаларининг корхона фармакопея мақолалари тасдиқланади;</a></div><div class="ACT_TEXT"><a id="7857621">Марказ директори томонидан маҳаллий дори воситаларининг тиббиётда қўлланилишига доир йўриқномалар тасдиқланади, хорижий дори воситаларининг тиббиётда қўлланилишига доир йўриқномалар келишилади;</a></div><div class="ACT_TEXT"><a id="7857623">г) клиник тадқиқотларни ўтказиш ва уларнинг натижасини экспертиза қилиш:</a></div><div class="ACT_TEXT"><a id="7857625">Марказ томонидан дори воситаларининг клиник тадқиқотлар ёки клиник тадқиқотларсиз рўйхатдан ўтказиш бўйича хулоса расмийлаштирилади;</a></div><div class="ACT_TEXT"><a id="7857627">Марказ клиник тадқиқотлар ўтказиш учун клиник тадқиқотлар турлари ва клиник базаларни белгилайди, клиник тадқиқотлар дастурларини ва баённомаларини экспертизадан ўтказади ва бажарилиши мажбурий бўлган кўрсатмани ариза берувчига ахборот тизими орқали юборади;</a></div><div class="ACT_TEXT"><a id="7857628">ариза берувчи ўтказилган клиник тадқиқот ҳисоботини Марказга ахборот тизими орқали юборади.</a></div><div class="ACT_TEXT"><a id="7857631">Қуйидаги ҳолларда рўйхатдан ўтказишда клиник тадқиқотлар ўтказиш талаб этилмайди:</a></div><div class="BY_DEFAULT"><a id="8082524"></a></div><div class="ACT_TEXT"><a id="8082525">халқаро кўп марказли клиник тадқиқотларнинг ижобий натижаларига мувофиқ тақдим этилган оригинал дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857633">дори моддалари (субстанциялар);</a></div><div class="ACT_TEXT"><a id="7857634">тан олиш йўли билан рўйхатдан ўтказиладиган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857636">ЖССТ томонидан қайта малакаланган (prequalification) дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857638">Ўзбекистон Республикасида клиник тадқиқотлари олдин ўтказилган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857639">одам ҳужайраларини муҳим ўзгаришларсиз қайта ишлаш натижасида олинган ҳужайра технологияси асосида ишлаб чиқарилган биотехнология дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857641">Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан белгиланадиган тартибга мувофиқ клиник тадқиқотларсиз давлат рўйхатидан ўтказиладиган алоҳида дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857643">референт препаратга нисбатан биоэквивалентлиги валидацияланган in vivo ёки in vitro тадқиқот усулларидан фойдаланган ҳолда исботланган, натижалари миқдорий кўрсаткичлар шаклида тақдим этилган перорал женерик дори воситалари.</a></div><div class="ACT_TEXT"><a id="7857646">Ихтисослаштирилган экспертиза давомида ариза берувчи томонидан тақдим этилган ҳужжатлар асосида дори воситасини рўйхатдан ўтказиш даврида дори воситасининг клиник тадқиқотларини, шу жумладан биоэквивалентлик тадқиқотларининг GCP талабларига мувофиқ амалга оширилганлигини аниқлаш мақсадида инспекция ўтказиш зарурлиги ёки зарур эмаслиги тўғрисида қарор қабул қилинади.</a></div><div class="ACT_TEXT"><a id="7857648">Марказ томонидан биоэквивалентликни ўрганиш натижалари бўйича инспекция ўтказиш зарурлиги тўғрисидаги қарор Фармакология қўмитаси Илмий комиссиясининг хулосаси ҳамда қуйидаги омилларни комплекс баҳолаш асосида қабул қилинади:</a></div><div class="ACT_TEXT"><a id="7857651">а) биоэквивалентликни ўрганиш натижаларининг асослантирилмаган маълумотларини тақдим этиш;</a></div><div class="ACT_TEXT"><a id="7863868">б) аниқланган қийматларнинг айнан ушбу таъсир этувчи модда учун номувофиқлиги;</a></div><div class="ACT_TEXT"><a id="7857692">в) тақдим этилган клиник, статистик ёки таҳлилий маълумотлардан бирининг ишончсизлиги;</a></div><div class="ACT_TEXT"><a id="7857694">г) фармакокинетик тадқиқотларда биоэквивалентликни тасдиқламайдиган натижалар олинганлиги.</a></div><div class="ACT_TEXT"><a id="7857695">Дори воситаларининг клиник тадқиқотларини ўтказиш ва женерик дори воситаларининг биоэквивалентлигини ўрганиш тартиби Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан белгиланади.</a></div><div class="ACT_TEXT"><a id="7857696">2029 йил 1 январдан бошлаб женерик дори воситаларнинг биоэквивалентлигини халқаро ICH талабларига мувофиқ ўрганиш мажбурий ҳисобланади.</a></div><div class="ACT_TEXT"><a id="7857699">23. Дори воситаларини рўйхатдан ўтказиш экспертизалари натижасига мувофиқ Марказ томонидан қуйидаги қарорлардан бири қабул қилинади:</a></div><div class="ACT_TEXT"><a id="7857700">дори воситаларини рўйхатдан ўтказиш тўғрисида;</a></div><div class="ACT_TEXT"><a id="7857701">дори воситаларини рўйхатдан ўтказишни рад этиш тўғрисида.</a></div><div class="ACT_TEXT"><a id="7857703">24. Марказ томонидан қарор қабул қилинган кундан бошлаб икки иш кунидан кечикмай, ариза берувчига ушбу Низомга <a href="javascript:scrollText(7860215)">4-иловага</a> мувофиқ шаклдаги гувоҳнома ахборот тизими орқали юборилади ёки рўйхатдан ўтказиш рад этилганлиги тўғрисида, аниқ сабабларини кўрсатган ҳолда хабардор қилинади.</a></div><div class="ACT_TEXT"><a id="7857706">Марказ томонидан ариза берувчига гувоҳнома билан биргаликда дори воситаларига тасдиқланган корхона фармакопея мақолалари, истеъмол ўрами (шу жумладан, ёрлиғи) ва тиббиётда қўлланилишига доир йўриқномалар берилади.</a></div><div class="ACT_TEXT"><a id="7857707">25. Қуйидагилар рўйхатдан ўтказишни рад этиш учун асос ҳисобланади:</a></div><div class="ACT_TEXT"><a id="7857734">рўйхатдан ўтказиш учун зарур бўлган ҳужжатларда, дори воситалари намуналарида ихтисослаштирилган экспертиза натижалари бўйича аниқланган камчиликларнинг 90 кунлик муддат ичида бартараф этилмаганлиги;</a></div><div class="ACT_TEXT"><a id="7857736">тақдим этилган ҳужжатлар ва намуналарда маълумотларнинг ишончсиз, нотўғри ёки ёлғон эканлиги аниқланганда;</a></div><div class="ACT_TEXT"><a id="7857738">дори воситаларининг сифати, хавфсизлиги ва самарадорлигини тавсифловчи лаборатория синовлари, клиник тадқиқотлар, илмий баҳолаш якунлари бўйича асосланган салбий хулосаларнинг мавжудлиги. Бунда аризада кўрсатилган турли дозалар бўйича камида битта дозада номувофиқлик аниқланган тақдирда ҳам рўйхатдан ўтказиш рад этилади;</a></div><div class="ACT_TEXT"><a id="7857741">рўйхатдан ўтказиш ҳужжатларидаги маълумотлар таҳлили ва экспертизаси асосида дори воситасининг хавфсизлиги, сифати ва самарадорлиги ҳамда «фойда-хавф» нисбатини баҳолаш якунлари бўйича асосланган салбий хулосаларнинг мавжудлиги;</a></div><div class="ACT_TEXT"><a id="7857744">дори воситаси таркибидаги фаол моддалар комбинациясининг мақсадга мувофиқ эмаслиги;</a></div><div class="ACT_TEXT"><a id="7857746">Ўзбекистон Республикасининг Давлат фармакопеясида ёки Ўзбекистон Республикаси ҳудудида амал қилувчи деб эътироф этилган фармакопеяларда белгиланган ёки аввал рўйхатдан ўтказилган аналогларига нисбатан пастроқ сифат ва хавфсизлик кўрсаткичларига эга бўлган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857748">дори воситаси таркибида қўллаш учун таъқиқланган ва таркибида кўрсатилмаган номаълум моддаларнинг мавжудлиги;</a></div><div class="ACT_TEXT"><a id="7857750">аризачи томонидан дори воситасининг клиник самарадорлиги ва хавфсизлигининг тасдиқланмаганлиги;</a></div><div class="ACT_TEXT"><a id="7857753">фармаконазорат маълумотлари асосида аниқланган далиллар, жумладан, дори воситасининг умумий тавсифида келтирилган маълумотлар билан солиштирилганда ножўя таъсирлар тўғрисида хабар бериш даврийлигининг ошиши, дори воситаларининг «фойда-хавф» нисбатининг мақсадга мувофиқ эмаслигини кўрсатувчи ҳолатлар мавжудлиги;</a></div><div class="ACT_TEXT"><a id="7857755">киритилаётган ўзгартиришлар дори воситасининг «фойда-хавф» нисбатига салбий таъсир кўрсатган тақдирда;</a></div><div class="ACT_TEXT"><a id="7857760">далилларга асосланган тиббиёт асосида самарадорлиги ҳамда хавфсизлиги ўрганилган, лекин самарадорлиги исботланмаган дори воситалари;</a></div><div class="ACT_TEXT"><a id="7857763">технологиялар трансфери амалга оширилган корхонада дори воситаларини ишлаб чиқариш трансфер қилинган технологик жараёндан четга чиқишлар аниқланганда;</a></div><div class="ACT_TEXT"><a id="7857766">технологиялар трансфери асосида ишлаб чиқарилган дори воситалари сифатининг лаборатория синовлари натижасида номутаносиблик аниқланганда;</a></div><div class="ACT_TEXT"><a id="7857768">«Зарур амалиётлар маркази» давлат муассасаси томонидан ишлаб чиқарувчининг «Зарур ишлаб чиқариш амалиёти (GMP)» Ўзбекистон Республикаси миллий талабларига номувофиқ деб топилган хулосаси мавжуд бўлганда.</a></div><div class="ACT_TEXT"><a id="7857770">Рўйхатдан ўтказишнинг бошқа асосларга кўра, шу жумладан, мақсадга мувофиқ эмаслиги сабаблари бўйича рад этилишига йўл қўйилмайди.</a></div><div class="ACT_TEXT"><a id="7857772">Дори воситаларининг сифати бўйича асосланган салбий хулосаларнинг мавжудлиги юзасидан рўйхатдан ўтказиш рад этилгандан сўнг бир иш куни ичида Марказ томонидан «Зарур амалиётлар маркази» давлат муассасасига навбатдан ташқари инспекция ўтказиш бўйича тақдимнома киритилади.</a></div><div class="ACT_TEXT"><a id="7857774">26. Рўйхатдан ўтказиш рад этилганда ариза берувчига ахборот тизими орқали рад этишнинг аниқ сабаблари кўрсатилган ҳолда хабарнома юборилади.</a></div><div class="ACT_TEXT"><a id="7857777">27. Ариза берувчи рўйхатдан ўтказишнинг рад этилиши, шунингдек Марказ мансабдор шахсининг ҳаракати (ҳаракатсизлиги) юзасидан белгиланган тартибда шикоят қилиш ҳуқуқига эга.</a></div><div class="ACT_TEXT"><a id="7857779">28. Рўйхатдан ўтказилганлик гувоҳномасининг амал қилиш даврида ишлаб чиқарилиб, рўйхатдан ўтказилганлик гувоҳномасининг амал қилиш муддати ўтган дори воситалари гувоҳноманинг амал қилиш муддати ўтгандан сўнг 180 календарь куни давомида сифат назоратини ўтказишга, импорт ва реализация қилишга ҳамда тиббиёт амалиётида яроқлилик муддати ўтгунига қадар қўллашга рухсат этилади. Бунда дори воситаларининг сифат назорати гувоҳноманинг амал қилиш муддатида тасдиқланган ҳужжатлар талабларига мувофиқ ўтказилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857783">5-боб. Рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш</a></div><div class="ACT_TEXT"><a id="7857785">29. Дори воситаларининг рўйхатдан ўтказиш ҳужжатларида келтирилган маълумотлар гувоҳноманинг амал қилиш муддати давомида ва гувоҳноманинг амал қилиш муддатини узайтиришда ўзгарган тақдирда, ариза берувчи ахборот тизими орқали Марказга ўзгартириш ва қўшимчалар киритиш тўғрисидаги аризани ҳамда заруратга кўра тегишли ҳужжатлар, дори воситасининг намуналари ва референс стандарт намуналарини илова қилган ҳолда юборади.</a></div><div class="ACT_TEXT"><a id="7857786">Ўзгартиришлар дори воситасининг сифати, самарадорлиги ва хавфсизлигига салбий таъсир кўрсатиши мумкин бўлган ҳолатларда, Марказ рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритишни рад этади.</a></div><div class="ACT_TEXT"><a id="7857788">30. Ариза берувчининг рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш тўғрисидаги аризаси Марказ томонидан рўйхатдан ўтказиш учун белгиланган муддатларнинг 50 фоизидан ошмайдиган муддатларда кўриб чиқилади, бунда тан олиш йўли билан рўйхатдан ўтказилган дори воситаларининг рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш бундан мустасно.</a></div><div class="ACT_TEXT"><a id="7857790">Дори воситалари шартнома асосида ва технологиялар трансфери йўли билан ишлаб чиқарилганда, гувоҳномага қўшимча ишлаб чиқариш майдони тўғрисидаги маълумот маҳсулотларнинг лаборатория синовлари ва ишлаб чиқариш майдонининг «Зарур ишлаб чиқариш амалиёти (GMP)»нинг миллий талабларига мувофиқлиги юзасидан ўтказилган инспекция натижаларига кўра киритилади (тан олиш орқали давлат рўйхатидан ўтказиладиган, ЖССТ томонидан қайта малакаланган дори воситалари бундан мустасно).</a></div><div class="ACT_TEXT"><a id="7857793">Бунда технологиялар трансфери тўлиқ амалга оширилганлиги «Зарур амалиётлар маркази» давлат муассасаси томонидан қуйидаги ҳужжатлар экспертизаси асосида тасдиқланади:</a></div><div class="ACT_TEXT"><a id="7857796">технологиялар трансферини амалга оширишда томонларнинг сифатни таъминлаш бўйича шартномаси;</a></div><div class="ACT_TEXT"><a id="7857799">технологиялар трансфери дастури;</a></div><div class="ACT_TEXT"><a id="7857801">технологиялар трансфери эгасининг трансфер амалга оширилганлиги тўғрисидаги ҳисоботи.</a></div><div class="ACT_TEXT"><a id="7857803">Рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритилгандан сўнг технологиялар трансферини қабул қилган фармацевтика ташкилотида ўрнатилган тартибда йилига камида бир маротаба «Зарур ишлаб чиқариш амалиёти (GMP)»нинг миллий талаблари бўйича инспекция назорати ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857806">Технологиялар трансфери амалга оширилган майдондаги маҳсулот ишлаб чиқарилишининг трансфер қилинган технологик жараён технология эгаси майдонидаги маҳсулот ишлаб чиқарилишига мутаносиб эканлиги тасдиқланиши талаб этилади.</a></div><div class="ACT_TEXT"><a id="7857808">Ишлаб чиқарувчиларнинг рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш тўғрисидаги аризаси кўриб чиқилганлиги учун Марказнинг кўрсатиб ўтилган тартиботларни амалга оширишга кетган харажатлари асосида Ўзбекистон Республикаси Соғлиқни сақлаш вазирлиги томонидан тасдиқланган миқдорларда йиғим ундирилади.</a></div><div class="ACT_TEXT"><a id="7857810">Ҳужжатлар экспертизаси ва (ёки) лаборатория синовлари натижаларига асосан Марказ томонидан қуйидаги қарорлардан бири қабул қилинади:</a></div><div class="ACT_TEXT"><a id="7857812">рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш тўғрисида;</a></div><div class="ACT_TEXT"><a id="7857815">рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритишни рад этиш тўғрисида.</a></div><div class="ACT_TEXT"><a id="7857817">Рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритилгандан сўнг 180 календарь куни давомида дори воситаларининг Марказ томонидан мазкур қарор қабул қилингунга қадар рўйхатдан ўтказиш ҳужжатларида мавжуд бўлган маълумотларга мувофиқ ишлаб чиқарилишига ва импорт қилинишига, сифат назорати ўтказилишига, реализация қилинишига ҳамда яроқлилик муддатлари ўтгунига қадар муомалада бўлишига рухсат этилади.</a></div><div class="ACT_TEXT"><a id="7857818">31. Рўйхатдан ўтказиш ҳужжатларига ўзгартириш ва қўшимчалар киритиш гувоҳномада келтирилган маълумотларни ўзгартириш ва қўшимча киритишни талаб қилган тақдирда, рўйхатдан ўтказилганлик гувоҳномасига тегишли ўзгартириш ва қўшимчалар киритилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857820">6-боб. Гувоҳномани қайта расмийлаштириш, унинг амал қилиш муддатини узайтириш</a></div><div class="ACT_TEXT"><a id="7857859">32. Ариза берувчининг ишлаб чиқариш майдони жойлашган ери ва технологиялари ўзгармаган ҳолда қайта ташкил этилганда ёки номи ўзгарганда, ариза берувчи бир ой муддатда Марказга гувоҳномани қайта расмийлаштириш тўғрисида ахборот тизими орқали ариза бериши шарт.</a></div><div class="ACT_TEXT"><a id="7857861">33. Гувоҳномани қайта расмийлаштиришда Марказ томонидан тиббиёт амалиётида қўлланилишига рухсат этилган дори воситалари давлат реестрига ҳамда ахборот тизимига тегишли ўзгартиришлар киритилади.</a></div><div class="ACT_TEXT"><a id="7857863">Гувоҳнома Марказ томонидан 5 иш кунидан кўп бўлмаган муддатда қайта расмийлаштирилади.</a></div><div class="ACT_TEXT"><a id="7857865">Гувоҳнома қайта расмийлаштирганлиги муносабати билан ариза берувчининг рўйхатдан ўтказиш тўғрисидаги аризаси Марказ томонидан кўриб чиқилганлиги учун тўлов ундирилмайди.</a></div><div class="ACT_TEXT"><a id="7857867">34. Гувоҳноманинг амал қилиш муддати ариза берувчи томонидан Марказга ахборот тизими орқали берилган аризасига биноан узайтирилиши мумкин. Гувоҳноманинг амал қилиш муддатини узайтириш тўғрисидаги ариза Марказга унинг амал қилиш муддати тугашидан олдин тўққиз ой ичида берилиши керак. Гувоҳноманинг амал қилиш муддатини узайтириш рўйхатдан ўтказиш учун назарда тутилган тартибда амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7857869">Дори воситалари гувоҳномасининг амал қилиш муддатини узайтириш жараёнида рўйхатдан ўтказиш ҳужжатларига ишлаб чиқариш жараёнлари, жумладан таъсир этувчи модданинг (субстанция) ишлаб чиқарувчиси, ёрдамчи моддалар таркиби, қадоғи, сифат назорати усуллари, меъёрлари ва ишлаб чиқариш технологияси билан боғлиқ ўзгартиришлар киритилмаган тақдирда, лаборатория синовлари ўтказилмайди. Бунда лаборатория синовларисиз амал қилиш муддати узайтирилган дори воситаларининг сифати мажбурий тартибда постмаркетинг назоратидан ўтказилади.</a></div><div class="ACT_TEXT"><a id="7857872">Гувоҳноманинг амал қилиш муддати узайтирилганидан сўнг 180 календарь куни давомида дори воситаларининг олдинги рўйхатдан ўтказиш ҳужжатларида мавжуд бўлган маълумотларга мувофиқ ишлаб чиқарилишига ва импорт қилинишига, сифат назорати ўтказилишига, реализация қилинишига ҳамда яроқлилик муддатлари ўтгунига қадар муомалада бўлишига рухсат этилади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857874">7-боб. Гувоҳноманинг амал қилишини тўхтатиб туриш, бекор қилиш ва уни тугатиш</a></div><div class="ACT_TEXT"><a id="7857876">35. Гувоҳноманинг амал қилишини тўхтатиб туриш, бекор қилиш ва уни тугатиш Ўзбекистон Республикасининг «Лицензиялаш, рухсат бериш ва хабардор қилиш тартиб-таомиллари тўғрисида»ги Қонунининг <a href="http://lex.uz/docs/5511879#5515487">32 — 34-моддаларида</a> назарда тутилган ҳолатларда ва тартибда амалга оширилади.</a></div><div class="ACT_TEXT"><a id="7857878">36. Мазкур Низомнинг 13-банди <a href="javascript:scrollText(7857411)">учинчи-тўртинчи</a> ва <a href="javascript:scrollText(7857416)">олтинчи — ўнинчи хатбошиларида</a> назарда тутилган рўйхатдан ўтказиш талаблари ва шартларининг бузилиши бир маротаба қўпол равишда бузилиш деб баҳоланади ва гувоҳноманинг амал қилинишини белгиланган тартибда бекор қилиш учун асос бўлади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857880">8-боб. Дори воситалари ва тиббий жиҳозлар давлат реестри</a></div><div class="ACT_TEXT"><a id="7857882">37. Марказ Тиббиёт амалиётида қўлланилишига рухсат этилган дори воситалари ва тиббий жиҳозлар давлат реестрини (кейинги ўринларда — Давлат реестри) юритади. Давлат реестри Ўзбекистон Республикаси Соғлиқни сақлаш вазирлигининг ва Марказнинг расмий веб-сайтида жойлаштиради.</a></div><div class="ACT_TEXT"><a id="7857884">Давлат реестрининг дори воситаларига тегишли бўлимларида қуйидаги маълумотлар кўрсатилади:</a></div><div class="ACT_TEXT"><a id="7857885">дори воситасининг савдо номи (доривор ўсимлик хомашёсининг номи, доривор ўсимликнинг биноминал илмий номи, ўсимлик қисмлари номи, бошқа номлар (бошқа фармакопеяда кўрсатилган синонимлар) билан берилади);</a></div><div class="ACT_TEXT"><a id="7857886">дори воситасининг келиб чиқиши (оригинал/женерик/биосимиляр/ ўсимликдан олинган дори воситаси, гомеопатик восита, тиббий иммунобиологик препарат);</a></div><div class="ACT_TEXT"><a id="7857889">дори воситаси таъсир этувчи моддасининг халқаро патентланмаган, гуруҳланган ёки кимёвий номи, дозаси, чиқарилиш шакли;</a></div><div class="ACT_TEXT"><a id="7857891">ишлаб чиқарувчи давлатнинг номи;</a></div><div class="ACT_TEXT"><a id="7857893">ишлаб чиқарувчининг (ишлаб чиқувчининг) номи, ташкилий-ҳуқуқий шакли, давлати, манзили;</a></div><div class="ACT_TEXT"><a id="7857895">дори воситаси гувоҳномасининг эгаси;</a></div><div class="ACT_TEXT"><a id="7857896">дори воситасининг фармакотерапевтик гуруҳи, ATC (АТХ, АТК) (анатомо-терапевтик-кимёвий) коди;</a></div><div class="ACT_TEXT"><a id="7857899">дори моддасини (субстанцияни) ишлаб чиқарувчининг (ишлаб чиқувчининг) номи, ташкилий-ҳуқуқий шакли, давлати, манзили;</a></div><div class="ACT_TEXT"><a id="7857901">гувоҳнома рақами;</a></div><div class="ACT_TEXT"><a id="7857902">гувоҳнома берилган сана;</a></div><div class="ACT_TEXT"><a id="7857920">дори воситасининг рецепт билан ёки рецептсиз берилиши;</a></div><div class="ACT_TEXT"><a id="7857921">зарур ҳолларда, гувоҳномага ўзгартириш ва (ёки) қўшимчалар киритилган сана.</a></div><div class="ACT_TEXT"><a id="7857923">38. Давлат реестридаги маълумотлар барча танишиши учун очиқ ҳисобланади.</a></div><div class="TEXT_HEADER_DEFAULT"><a id="7857925">9-боб. Якунловчи қоида</a></div><div class="ACT_TEXT"><a id="7857926">39. Мазкур Низом талаблари бузилишида айбдор бўлган шахслар қонунчилик ҳужжатларида белгиланган тартибда жавоб берадилар.</a></div><div class="BY_DEFAULT"><a id="7858079"></a></div><div class="APPL_BANNER_LANDSCAPE_TITLE"><a id="7858081">Дори воситаларини давлат рўйхатидан ўтказиш тартиби тўғрисидаги <a href="javascript:scrollText(7857023)">низомга</a><br />1-ИЛОВА</a></div><div class="ACT_TITLE_APPL"><a id="7858083">Дори воситаларини давлат рўйхатидан ўтказиш</a></div><div class="ACT_FORM"><a id="7858085">СХЕМАЛАРИ ВА МУДДАТЛАРИ</a></div><div class="BY_DEFAULT"><a id="7858087"></a></div><div class="BY_DEFAULT"><a id="7858090"><table class="Table" style="width:100.0%; border-collapse:collapse; border:none" width="100%"><tbody><tr><td rowspan="2" style="border-bottom:1px solid black; width:2%; padding:0cm 4px 0cm 4px; background-color:white; border-top:1px solid black; border-right:1px solid black; border-left:1px solid black"><p align="center" class="CxSpFirst" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Т/р</span></span></b></span></span></p></td><td rowspan="2" style="border-bottom:1px solid black; width:6%; padding:0cm 4px 0cm 4px; background-color:white; border-top:1px solid black; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Босқичлар</span></span></b></span></span></p></td><td rowspan="2" style="border-bottom:1px solid black; width:8%; padding:0cm 4px 0cm 4px; background-color:white; border-top:1px solid black; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Субъектлар</span></span></b></span></span></p></td><td rowspan="2" style="border-bottom:1px solid black; width:25%; padding:0cm 4px 0cm 4px; background-color:white; border-top:1px solid black; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Чора-тадбирлар</span></span></b></span></span></p></td><td colspan="5" style="border-bottom:1px solid black; width:55%; padding:0cm 4px 0cm 4px; background-color:white; border-top:1px solid black; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Муддатлар</span></span></b></span></span><a href="javascript:scrollText(7858093)">*</a></p></td></tr><tr><td style="border-bottom:1px solid black; width:11%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Умумий тартибда рўйхатдан ўтказиш</span></span></b></span></span></p></td><td style="border-bottom:1px solid black; width:10%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Дори моддаси</span></span></b></span></span></p><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">(субстанция)</span></span></b></span></span></p></td><td style="border-bottom:1px solid black; width:14%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Гувоҳноманинг амал қилиш муддатини узайтириш</span></span></b></span></span><a href="javascript:scrollText(7858096)">**</a></p></td><td style="border-bottom:1px solid black; width:9%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">Тан олиш йўли билан рўйхатдан ўтказиш</span></span></b></span></span></p></td><td style="border-bottom:1px solid black; width:10%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><b><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">ЖССТ томонидан преквалификацияланган дори воситаларини рўйхатдан ўтказиш</span></span></b></span></span></p></td></tr><tr><td style="border-bottom:1px solid black; width:2%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:1px solid black"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">1.</span></span></span></span></p></td><td style="border-bottom:1px solid black; width:6%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpMiddle" style="text-align:center"><span style="line-height:normal"><span style="tab-stops:9.0cm"><span lang="UZ-CYR" style="font-size:12.0pt"><span style="font-family:&quot;Times New Roman&quot;,serif">1-босқич</span></span></span></span></p></td><td style="border-bottom:1px solid black; width:8%; padding:0cm 4px 0cm 4px; background-color:white; border-top:none; border-right:1px solid black; border-left:none"><p align="center" class="CxSpM